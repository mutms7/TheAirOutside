<Window x:Class="VisualNovel.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:local="clr-namespace:VisualNovel.Desktop"
        Title="The Air Outside"
        Width="1280" Height="800"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#FAF7F1">
    <Grid>
        <blazor:BlazorWebView x:Name="Blazor" HostPage="wwwroot\index.html">
            <blazor:BlazorWebView.RootComponents>
                <blazor:RootComponent Selector="#app" ComponentType="{x:Type local:Main}" />
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>
    </Grid>
</Window>
