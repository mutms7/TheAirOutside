@inject SettingsService SettingsSvc
@implements IDisposable

<div class="panel__header">
    <h2 class="panel__title">Settings</h2>
</div>

<div class="panel__body settings">
    <section class="settings__group">
        <h3 class="settings__group-title">Reading</h3>

        <div class="settings__row">
            <label class="settings__label">
                <input type="checkbox" checked="@s.AutoAdvance"
                       @onchange="@(async e => await Update(set => set.AutoAdvance = (bool)e.Value!))" />
                Auto-advance text
            </label>
            <p class="settings__hint">Off by default. Click anywhere to read at your own pace.</p>
        </div>

        @if (s.AutoAdvance)
        {
            <div class="settings__row">
                <label class="settings__label">Auto-advance delay <span class="settings__value">@s.AutoAdvanceDelay.ToString("0.0")s</span></label>
                <input type="range" min="1.0" max="10.0" step="0.5" value="@s.AutoAdvanceDelay"
                       @oninput="@(async e => await Update(set => set.AutoAdvanceDelay = double.Parse(e.Value!.ToString()!)))" />
            </div>
        }

        <div class="settings__row">
            <label class="settings__label">Text fade <span class="settings__value">@s.TextFadeMs.ToString("0")ms</span></label>
            <input type="range" min="0" max="500" step="25" value="@s.TextFadeMs"
                   @oninput="@(async e => await Update(set => set.TextFadeMs = double.Parse(e.Value!.ToString()!)))" />
        </div>

        <div class="settings__row">
            <label class="settings__label">Text size <span class="settings__value">@s.TextSize.ToString("0.##")×</span></label>
            <input type="range" min="0" max="5" step="1" value="@TextSizeIndex" list="text-size-marks"
                   @oninput="OnTextSizeInput" />
            <datalist id="text-size-marks">
                <option value="0"></option>
                <option value="1"></option>
                <option value="2"></option>
                <option value="3"></option>
                <option value="4"></option>
                <option value="5"></option>
            </datalist>
            <div class="settings__slider-marks">
                @foreach (var v in TextSizes)
                {
                    <span class="settings__slider-mark @(Math.Abs(s.TextSize - v) < 0.005 ? "settings__slider-mark--active" : "")">@v.ToString("0.##")×</span>
                }
            </div>
        </div>
    </section>

    <section class="settings__group">
        <h3 class="settings__group-title">Display</h3>

        <div class="settings__row settings__row--inline">
            <label class="settings__label">Theme</label>
            <div class="settings__seg">
                <button class="settings__seg-btn @(s.Theme == "light" ? "settings__seg-btn--active" : "")"
                        @onclick="@(async () => await Update(set => set.Theme = "light"))">light</button>
                <button class="settings__seg-btn @(s.Theme == "dark" ? "settings__seg-btn--active" : "")"
                        @onclick="@(async () => await Update(set => set.Theme = "dark"))">dark</button>
            </div>
        </div>

        <div class="settings__row">
            <label class="settings__label">
                <input type="checkbox" checked="@s.ReduceMotion"
                       @onchange="@(async e => await Update(set => set.ReduceMotion = (bool)e.Value!))" />
                Reduce motion
            </label>
            <p class="settings__hint">Disables fade animations. Recommended for vestibular sensitivity.</p>
        </div>
    </section>

    <section class="settings__group">
        <h3 class="settings__group-title">Audio</h3>
        <p class="settings__hint">Audio is not wired in the prototype. Sliders save for the future.</p>

        <div class="settings__row">
            <label class="settings__label">Master <span class="settings__value">@((int)(s.MasterVolume * 100))%</span></label>
            <input type="range" min="0" max="1" step="0.05" value="@s.MasterVolume"
                   @oninput="@(async e => await Update(set => set.MasterVolume = double.Parse(e.Value!.ToString()!)))" />
        </div>

        <div class="settings__row">
            <label class="settings__label">Music <span class="settings__value">@((int)(s.MusicVolume * 100))%</span></label>
            <input type="range" min="0" max="1" step="0.05" value="@s.MusicVolume"
                   @oninput="@(async e => await Update(set => set.MusicVolume = double.Parse(e.Value!.ToString()!)))" />
        </div>

        <div class="settings__row">
            <label class="settings__label">Sound effects <span class="settings__value">@((int)(s.SfxVolume * 100))%</span></label>
            <input type="range" min="0" max="1" step="0.05" value="@s.SfxVolume"
                   @oninput="@(async e => await Update(set => set.SfxVolume = double.Parse(e.Value!.ToString()!)))" />
        </div>
    </section>

    <section class="settings__group">
        <div class="settings__row">
            <button class="settings__reset" @onclick="ResetDefaults">Reset to defaults</button>
            <p class="settings__hint">Returns every setting to its starting value. Your save and progress are not affected.</p>
        </div>
    </section>
</div>

@code {
    private GameSettings s => SettingsSvc.Current;

    private static readonly double[] TextSizes = { 0.75, 1.0, 1.25, 1.5, 1.75, 2.0 };

    private int TextSizeIndex
    {
        get
        {
            for (int i = 0; i < TextSizes.Length; i++)
                if (Math.Abs(s.TextSize - TextSizes[i]) < 0.01) return i;
            return 1; // default to 1.0
        }
    }

    protected override void OnInitialized() => SettingsSvc.Changed += OnChanged;
    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async Task Update(Action<GameSettings> mutate)
    {
        await SettingsSvc.UpdateAsync(mutate);
    }

    private async Task OnTextSizeInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0 && idx < TextSizes.Length)
        {
            await Update(set => set.TextSize = TextSizes[idx]);
        }
    }

    private async Task ResetDefaults()
    {
        await SettingsSvc.UpdateAsync(set => {
            set.AutoAdvance = false;
            set.AutoAdvanceDelay = 3.5;
            set.TextFadeMs = 150;
            set.TextSize = 1.0;
            set.MasterVolume = 0.8;
            set.MusicVolume = 0.7;
            set.SfxVolume = 0.8;
            set.Theme = "light";
            set.ReduceMotion = false;
        });
    }

    public void Dispose() => SettingsSvc.Changed -= OnChanged;
}
