                            <ellipse cx="100" cy="58" rx="34" ry="42" fill="#D9B89C"/>
                            <path d="M 66 50 Q 100 16 134 50 L 138 110 Q 132 95 130 80 Q 100 95 70 80 Q 68 95 62 110 Z" fill="#2A2018"/>
                            <circle cx="88" cy="60" r="2" fill="#2A2A30"/>
                            <circle cx="112" cy="60" r="2" fill="#2A2A30"/>
                            @if (Expression == "looking-at-wren")
                            {
                                <path d="M 92 76 L 108 76" stroke="#2A2A30" stroke-width="1.5" fill="none"/>
                            }
                            else
                            {
                                <path d="M 92 76 Q 100 77 108 76" stroke="#2A2A30" stroke-width="1.5" fill="none"/>
                            }
                            <rect x="92" y="100" width="16" height="20" fill="#D9B89C"/>
                            <rect x="42" y="120" width="116" height="220" rx="8" fill="#7A7A6A"/>
                            <rect x="42" y="120" width="116" height="30" rx="8" fill="#8B8B7A"/>
                            <rect x="22" y="125" width="30" height="210" rx="14" fill="#7A7A6A"/>
                            <rect x="148" y="125" width="30" height="210" rx="14" fill="#7A7A6A"/>
                            <circle cx="37" cy="338" r="10" fill="#D9B89C"/>
                            <line x1="32" y1="334" x2="36" y2="338" stroke="#9B7050" stroke-width="1"/>
                            <line x1="38" y1="332" x2="40" y2="336" stroke="#9B7050" stroke-width="1"/>
                            <circle cx="163" cy="338" r="10" fill="#D9B89C"/>
                            <rect x="60" y="328" width="35" height="130" rx="4" fill="#3F3F38"/>
                            <rect x="105" y="328" width="35" height="130" rx="4" fill="#3F3F38"/>
                            <svg:text x="100" y="230" text-anchor="middle" font-family="serif" font-weight="500" font-size="12" fill="#5C5C54" letter-spacing="5" opacity="0.7">I R I S</svg:text>
                        </svg>
                        break;
                    default:
                        <svg class="character__art" viewBox="0 0 200 460" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
                            <defs>
                                <linearGradient id="iris-suit" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%"  stop-color="#CFC8C0"/>
                                    <stop offset="55%" stop-color="#B8B0A8"/>
                                    <stop offset="100%" stop-color="#928A82"/>
                                </linearGradient>
                                <linearGradient id="iris-helmet" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%"  stop-color="#CFC8C0"/>
                                    <stop offset="100%" stop-color="#A09890"/>
                                </linearGradient>
                                <linearGradient id="iris-limb" x1="0" y1="0" x2="1" y2="0">
                                    <stop offset="0%"  stop-color="#9C948B"/>
                                    <stop offset="50%" stop-color="#B8B0A8"/>
                                    <stop offset="100%" stop-color="#9C948B"/>
                                </linearGradient>
                            </defs>
                            <ellipse cx="100" cy="60" rx="55" ry="60" fill="url(#iris-helmet)"/>
                            <ellipse cx="80" cy="30" rx="22" ry="14" fill="#FFFFFF" opacity="0.18"/>
                            <path d="M 50 50 Q 100 46 150 50 L 150 72 Q 100 76 50 72 Z" fill="#1F2026" opacity="0.92"/>
                            <path d="M 50 50 Q 100 46 150 50 L 150 56 Q 100 52 50 56 Z" fill="#FFFFFF" opacity="0.10"/>
                            <rect x="80" y="115" width="40" height="20" rx="3" fill="#9C948B"/>
                            <path d="M 52 135 Q 100 130 148 135 Q 152 220 150 260 Q 148 296 145 315 L 55 315 Q 52 296 50 260 Q 48 220 52 135 Z" fill="url(#iris-suit)"/>
                            <path d="M 56 138 Q 100 134 144 138 L 144 154 Q 100 148 56 154 Z" fill="#FFFFFF" opacity="0.18"/>
                            <line x1="100" y1="135" x2="100" y2="315" stroke="#7F7770" stroke-width="1.5" opacity="0.7"/>
                            <svg:text x="100" y="230" text-anchor="middle" font-family="serif" font-weight="600" font-size="13" fill="#5C5C54" letter-spacing="5">I R I S</svg:text>
                            <path d="M 18 152 Q 18 140 30 140 L 41 140 Q 53 140 53 152 L 53 338 Q 53 350 41 350 L 30 350 Q 18 350 18 338 Z" fill="url(#iris-limb)"/>
                            <path d="M 147 152 Q 147 140 159 140 L 170 140 Q 182 140 182 152 L 182 338 Q 182 350 170 350 L 159 350 Q 147 350 147 338 Z" fill="url(#iris-limb)"/>
                            <rect x="20"  y="142" width="6" height="200" rx="3" fill="#FFFFFF" opacity="0.16"/>
                            <rect x="149" y="142" width="6" height="200" rx="3" fill="#FFFFFF" opacity="0.16"/>
                            <path d="M 58 315 Q 58 312 62 312 L 138 312 Q 142 312 142 315 L 142 345 L 58 345 Z" fill="#9C948B"/>
                            <path d="M 60 348 Q 60 345 64 345 L 91 345 Q 95 345 95 348 L 95 458 Q 95 460 92 460 L 63 460 Q 60 460 60 458 Z" fill="url(#iris-suit)"/>
                            <path d="M 105 348 Q 105 345 109 345 L 136 345 Q 140 345 140 348 L 140 458 Q 140 460 137 460 L 108 460 Q 105 460 105 458 Z" fill="url(#iris-suit)"/>
                        </svg>
                        break;
                }
                break;

            case "ozaki":
                @switch (Expression)
                {
                    case "bare":
                    case "dancing":
                        <svg class="character__art" viewBox="0 0 200 460" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
                            <ellipse cx="100" cy="60" rx="34" ry="40" fill="#C9A685"/>
                            <path d="M 66 52 Q 100 28 134 52 Q 136 42 100 38 Q 64 42 66 52" fill="#1F1A14"/>
                            <circle cx="88" cy="60" r="2" fill="#2A2A30"/>
                            <circle cx="112" cy="60" r="2" fill="#2A2A30"/>
                            <path d="M 92 76 L 108 76" stroke="#2A2A30" stroke-width="1.5" fill="none"/>
                            <rect x="92" y="100" width="16" height="22" fill="#C9A685"/>
                            <rect x="40" y="122" width="120" height="50" fill="#E8E0D2"/>
                            <line x1="80" y1="120" x2="120" y2="120" stroke="#8B7762" stroke-width="2"/>
                            <line x1="80" y1="120" x2="80" y2="170" stroke="#8B7762" stroke-width="1" opacity="0.5"/>
                            <line x1="120" y1="120" x2="120" y2="170" stroke="#8B7762" stroke-width="1" opacity="0.5"/>
                            <rect x="40" y="170" width="120" height="160" fill="#E8E0D2"/>
                            @if (Expression == "dancing")
                            {
                                <rect x="22" y="135" width="20" height="120" rx="8" fill="#C9A685" transform="rotate(-20 32 195)"/>
                                <rect x="158" y="135" width="20" height="130" rx="8" fill="#C9A685" transform="rotate(15 168 200)"/>
                                <circle cx="14" cy="120" r="10" fill="#C9A685" transform="rotate(-20 32 195)"/>
                                <circle cx="186" cy="265" r="10" fill="#C9A685" transform="rotate(15 168 200)"/>
                            }
                            else
                            {
                                <rect x="22" y="130" width="20" height="200" rx="8" fill="#C9A685"/>
                                <rect x="158" y="130" width="20" height="200" rx="8" fill="#C9A685"/>
                                <circle cx="32" cy="338" r="10" fill="#C9A685"/>
                                <circle cx="168" cy="338" r="10" fill="#C9A685"/>
                            }
                            <rect x="60" y="330" width="35" height="130" rx="4" fill="#3A2E20"/>
                            <rect x="105" y="330" width="35" height="130" rx="4" fill="#3A2E20"/>
                        </svg>
                        break;
                    default:
                        <svg class="character__art" viewBox="0 0 200 460" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
                            <defs>
                                <linearGradient id="oz-suit" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%"  stop-color="#827F68"/>
                                    <stop offset="55%" stop-color="#6B6855"/>
                                    <stop offset="100%" stop-color="#494636"/>
                                </linearGradient>
                                <linearGradient id="oz-helmet" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%"  stop-color="#827F68"/>
                                    <stop offset="100%" stop-color="#56533F"/>
                                </linearGradient>
                                <linearGradient id="oz-limb" x1="0" y1="0" x2="1" y2="0">
                                    <stop offset="0%"  stop-color="#525040"/>
                                    <stop offset="50%" stop-color="#6B6855"/>
                                    <stop offset="100%" stop-color="#525040"/>
                                </linearGradient>
                            </defs>
                            <ellipse cx="100" cy="60" rx="55" ry="60" fill="url(#oz-helmet)"/>
                            <ellipse cx="80" cy="30" rx="22" ry="14" fill="#FFFFFF" opacity="0.12"/>
                            <path d="M 50 50 Q 100 46 150 50 L 150 72 Q 100 76 50 72 Z" fill="#1F2026" opacity="0.92"/>
                            <path d="M 50 50 Q 100 46 150 50 L 150 56 Q 100 52 50 56 Z" fill="#FFFFFF" opacity="0.08"/>
                            <rect x="56" y="56" width="8" height="6" rx="1" fill="#A8E6CF" opacity="0.65"/>
                            <rect x="80" y="115" width="40" height="20" rx="3" fill="#3F3D2E"/>
                            <path d="M 52 135 Q 100 130 148 135 Q 152 220 150 260 Q 148 296 145 315 L 55 315 Q 52 296 50 260 Q 48 220 52 135 Z" fill="url(#oz-suit)"/>
                            <path d="M 56 138 Q 100 134 144 138 L 144 154 Q 100 148 56 154 Z" fill="#FFFFFF" opacity="0.14"/>
                            <line x1="100" y1="135" x2="100" y2="315" stroke="#3F3D2E" stroke-width="1.5" opacity="0.7"/>
                            <svg:text x="100" y="230" text-anchor="middle" font-family="serif" font-weight="500" font-size="11" fill="#1F1D10" letter-spacing="4">O Z A K I</svg:text>
                            <path d="M 18 152 Q 18 140 30 140 L 41 140 Q 53 140 53 152 L 53 338 Q 53 350 41 350 L 30 350 Q 18 350 18 338 Z" fill="url(#oz-limb)"/>
                            <path d="M 147 152 Q 147 140 159 140 L 170 140 Q 182 140 182 152 L 182 338 Q 182 350 170 350 L 159 350 Q 147 350 147 338 Z" fill="url(#oz-limb)"/>
                            <rect x="20"  y="142" width="6" height="200" rx="3" fill="#FFFFFF" opacity="0.12"/>
                            <rect x="149" y="142" width="6" height="200" rx="3" fill="#FFFFFF" opacity="0.12"/>
                            @if (Expression == "reading")
                            {
                                <g transform="rotate(-5 80 305)">
                                    <rect x="40" y="280" width="80" height="50" rx="2" fill="#FAF7F1"/>
                                    <rect x="40" y="280" width="80" height="6" fill="#FFFFFF" opacity="0.55"/>
                                    <line x1="80" y1="280" x2="80" y2="330" stroke="#8B7762" stroke-width="1.2"/>
                                    <line x1="48" y1="295" x2="73" y2="295" stroke="#7A6957" stroke-width="0.6" opacity="0.5"/>
                                    <line x1="48" y1="304" x2="73" y2="304" stroke="#7A6957" stroke-width="0.6" opacity="0.5"/>
                                    <line x1="48" y1="313" x2="73" y2="313" stroke="#7A6957" stroke-width="0.6" opacity="0.5"/>
                                </g>
                            }
                            <rect x="18" y="337" width="35" height="20" rx="10" fill="#3F3D2E"/>
                            <rect x="147" y="337" width="35" height="20" rx="10" fill="#3F3D2E"/>
                            <path d="M 58 315 Q 58 312 62 312 L 138 312 Q 142 312 142 315 L 142 345 L 58 345 Z" fill="#3F3D2E"/>
                            <path d="M 60 348 Q 60 345 64 345 L 91 345 Q 95 345 95 348 L 95 458 Q 95 460 92 460 L 63 460 Q 60 460 60 458 Z" fill="url(#oz-suit)"/>
                            <path d="M 105 348 Q 105 345 109 345 L 136 345 Q 140 345 140 348 L 140 458 Q 140 460 137 460 L 108 460 Q 105 460 105 458 Z" fill="url(#oz-suit)"/>
                        </svg>
                        break;
                }
                break;

            case "cael":
                <svg class="character__art" viewBox="0 0 200 460" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
                    <defs>
                        <linearGradient id="cl-suit" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%"  stop-color="#FFE082"/>
                            <stop offset="55%" stop-color="#FFD24A"/>
