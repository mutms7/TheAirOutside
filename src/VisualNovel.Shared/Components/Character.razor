@code {
    [Parameter] public string Id { get; set; } = "";

    private string Name => Id.Split(' ', 2)[0].ToLowerInvariant();
    private string Expression => Id.Contains(' ') ? Id.Split(' ', 2)[1] : "neutral";

    private string Color => Name switch
    {
        "wren"    => "#F5B68C",
        "tae"     => "#FF6B9D",
        "iris"    => "#B8B0A8",
        "ozaki"   => "#6B6855",
        "cael"    => "#FFD24A",
        "janitor" => "#888888",
        _         => "#CCCCCC",
    };

    private string ProtagonistName
    {
        get
        {
            var v = StoryService.GetVar("protagonist_name");
            return string.IsNullOrEmpty(v) ? "WREN" : v.ToUpper();
        }
    }

    private string SpacedName(string n)
    {
        if (string.IsNullOrEmpty(n)) return "";
        var chars = n.ToUpper().ToCharArray();
        return string.Join(" ", chars);
    }
}
