@inject StoryService StoryService

@if (!string.IsNullOrEmpty(Id))
{
    <div class="character character--@Name character--@(Name)-@Expression" @key="@Name">
        @switch (Name)
        {
            case "wren":
                @switch (Expression)
                {
                    case "bare":
                    case "bare-cry":
