                            <path d="M 64 56 Q 100 18 136 56 Q 138 30 100 26 Q 62 30 64 56" fill="#3A2818"/>
                            <circle cx="88" cy="@(Expression == "bare-cry" ? "66" : "62")" r="2" fill="#2A2A30"/>
                            <circle cx="112" cy="@(Expression == "bare-cry" ? "66" : "62")" r="2" fill="#2A2A30"/>
                            @if (Expression == "bare-cry")
                            {
                                <path d="M 92 78 Q 100 76 108 78" stroke="#2A2A30" stroke-width="1.5" fill="none"/>
                                <line x1="88" y1="70" x2="86" y2="86" stroke="#9CC0E0" stroke-width="2"/>
                            }
                            else
                            {
                                <path d="M 92 78 Q 100 80 108 78" stroke="#2A2A30" stroke-width="1.5" fill="none"/>
                            }
                            <rect x="92" y="103" width="16" height="18" fill="#E5BC97"/>
                            <rect x="54" y="121" width="92" height="200" rx="8" fill="#D4C4B0"/>
                            <rect x="29" y="126" width="28" height="208" rx="14" fill="#D4C4B0"/>
                            <rect x="143" y="126" width="28" height="208" rx="14" fill="#D4C4B0"/>
                            <circle cx="43" cy="338" r="11" fill="#E5BC97"/>
                            <circle cx="157" cy="338" r="11" fill="#E5BC97"/>
                            <rect x="59" y="319" width="36" height="138" rx="5" fill="#5C5447"/>
                            <rect x="105" y="319" width="36" height="138" rx="5" fill="#5C5447"/>
                            <svg:text x="100" y="200" text-anchor="middle" font-family="serif" font-weight="500" font-size="11" fill="#A89580" letter-spacing="4">@SpacedName(ProtagonistName)</svg:text>
                        </svg>
                        break;
                    default:
                        <svg class="character__art" viewBox="0 0 200 460" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
                            <defs>
                                <linearGradient id="wren-suit" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%"  stop-color="#FBC79C"/>
                                    <stop offset="55%" stop-color="#F5B68C"/>
                                    <stop offset="100%" stop-color="#DA9968"/>
                                </linearGradient>
                                <linearGradient id="wren-helmet" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%"  stop-color="#FBC79C"/>
                                    <stop offset="100%" stop-color="#E9A47A"/>
                                </linearGradient>
                                <linearGradient id="wren-limb" x1="0" y1="0" x2="1" y2="0">
                                    <stop offset="0%"  stop-color="#E0A074"/>
                                    <stop offset="50%" stop-color="#F5B68C"/>
                                    <stop offset="100%" stop-color="#E0A074"/>
                                </linearGradient>
                            </defs>
                            @{
                                var tilt = Expression == "troubled" ? 4 : 0;
                                var headY = 60 + (Expression == "troubled" ? 8 : 0);
                            }
                            <g transform="translate(@tilt 0)">
                                <ellipse cx="100" cy="@headY" rx="55" ry="60" fill="url(#wren-helmet)"/>
                                <ellipse cx="80" cy="@(headY - 30)" rx="22" ry="14" fill="#FFFFFF" opacity="0.16"/>
                                <path d="M 50 @(headY - 10) Q 100 @(headY - 14) 150 @(headY - 10) L 150 @(headY + 12) Q 100 @(headY + 16) 50 @(headY + 12) Z" fill="#1F2026" opacity="0.92"/>
                                <path d="M 50 @(headY - 10) Q 100 @(headY - 14) 150 @(headY - 10) L 150 @(headY - 4) Q 100 @(headY - 8) 50 @(headY - 4) Z" fill="#FFFFFF" opacity="0.10"/>
                                <rect x="56" y="@(headY - 4)" width="8" height="6" rx="1" fill="#A8E6CF" opacity="0.8"/>
                                <rect x="80" y="@(headY + 55)" width="40" height="20" rx="3" fill="#D89B70"/>
                            </g>
                            <path d="M 52 135 Q 100 130 148 135 Q 152 220 150 260 Q 148 296 145 315 L 55 315 Q 52 296 50 260 Q 48 220 52 135 Z" fill="url(#wren-suit)"/>
                            <path d="M 56 138 Q 100 134 144 138 L 144 152 Q 100 148 56 152 Z" fill="#FFFFFF" opacity="0.18"/>
                            <line x1="100" y1="135" x2="100" y2="315" stroke="#C68A5C" stroke-width="1.5" opacity="0.7"/>
                            <circle cx="65" cy="155" r="11" fill="#F5B68C" stroke="#C68A5C" stroke-width="1.4"/>
                            <circle cx="62" cy="151" r="3.5" fill="#FFFFFF" opacity="0.45"/>
                            <path d="M 56 152 Q 65 147 74 152" stroke="#A8E6CF" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                            <path d="M 18 152 Q 18 140 30 140 L 41 140 Q 53 140 53 152 L 53 338 Q 53 350 41 350 L 30 350 Q 18 350 18 338 Z" fill="url(#wren-limb)"/>
                            <path d="M 147 152 Q 147 140 159 140 L 170 140 Q 182 140 182 152 L 182 338 Q 182 350 170 350 L 159 350 Q 147 350 147 338 Z" fill="url(#wren-limb)"/>
                            <rect x="20" y="142" width="6" height="200" rx="3" fill="#FFFFFF" opacity="0.18"/>
                            <rect x="149" y="142" width="6" height="200" rx="3" fill="#FFFFFF" opacity="0.18"/>
                            <rect x="18" y="337" width="35" height="20" rx="10" fill="#D89B70"/>
                            <rect x="147" y="337" width="35" height="20" rx="10" fill="#D89B70"/>
                            <path d="M 58 315 Q 58 312 62 312 L 138 312 Q 142 312 142 315 L 142 345 L 58 345 Z" fill="#D89B70"/>
                            <path d="M 60 348 Q 60 345 64 345 L 91 345 Q 95 345 95 348 L 95 458 Q 95 460 92 460 L 63 460 Q 60 460 60 458 Z" fill="url(#wren-suit)"/>
                            <path d="M 105 348 Q 105 345 109 345 L 136 345 Q 140 345 140 348 L 140 458 Q 140 460 137 460 L 108 460 Q 105 460 105 458 Z" fill="url(#wren-suit)"/>
                            <rect x="62" y="350" width="5" height="100" rx="2" fill="#FFFFFF" opacity="0.16"/>
                            <rect x="107" y="350" width="5" height="100" rx="2" fill="#FFFFFF" opacity="0.16"/>
                            <svg:text x="100" y="230" text-anchor="middle" font-family="serif" font-weight="600" font-size="13" fill="#9B5B30" letter-spacing="4">@SpacedName(ProtagonistName)</svg:text>
                        </svg>
                        break;
                }
                break;

            case "tae":
                <svg class="character__art" viewBox="0 0 200 460" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
                    <defs>
                        <linearGradient id="tae-suit" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%"  stop-color="#FF8AB5"/>
                            <stop offset="55%" stop-color="#FF6B9D"/>
                            <stop offset="100%" stop-color="#E04A7A"/>
                        </linearGradient>
                        <linearGradient id="tae-helmet" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%"  stop-color="#FF8AB5"/>
                            <stop offset="100%" stop-color="#E55B8C"/>
                        </linearGradient>
                        <linearGradient id="tae-limb" x1="0" y1="0" x2="1" y2="0">
                            <stop offset="0%"  stop-color="#E04A7A"/>
                            <stop offset="50%" stop-color="#FF6B9D"/>
                            <stop offset="100%" stop-color="#E04A7A"/>
                        </linearGradient>
                    </defs>
                    <ellipse cx="100" cy="60" rx="55" ry="60" fill="url(#tae-helmet)"/>
                    <ellipse cx="80" cy="30" rx="22" ry="14" fill="#FFFFFF" opacity="0.22"/>
                    <path d="M 50 50 Q 100 46 150 50 L 150 72 Q 100 76 50 72 Z" fill="#1F2026" opacity="0.92"/>
                    <path d="M 50 50 Q 100 46 150 50 L 150 56 Q 100 52 50 56 Z" fill="#FFFFFF" opacity="0.12"/>
                    @if (Expression == "warm" || Expression == "private")
                    {
                        <path d="M 50 50 Q 100 46 150 50 L 150 56 Q 100 52 50 56 Z" fill="#FFA0C0"/>
                    }
                    <rect x="56" y="56" width="8" height="6" rx="1" fill="#A8E6CF" opacity="0.8"/>
                    <rect x="80" y="115" width="40" height="20" rx="3" fill="#E04A7A"/>
                    @if (Expression != "private")
                    {
                        <g>
                            <circle cx="70" cy="128" r="3" fill="#FFD700"/>
                            <circle cx="100" cy="130" r="3" fill="#FFD700"/>
                            <circle cx="130" cy="128" r="3" fill="#FFD700"/>
                        </g>
                    }
                    <path d="M 52 135 Q 100 130 148 135 Q 152 220 150 260 Q 148 296 145 315 L 55 315 Q 52 296 50 260 Q 48 220 52 135 Z" fill="url(#tae-suit)"/>
                    <path d="M 56 138 Q 100 134 144 138 L 144 154 Q 100 148 56 154 Z" fill="#FFFFFF" opacity="0.22"/>
                    <line x1="100" y1="135" x2="100" y2="315" stroke="#C13868" stroke-width="1.5" opacity="0.7"/>
                    <g transform="translate(60, 155)">
                        <circle r="14" fill="#FFA0C0"/>
                        <circle r="9" fill="#FF6B9D"/>
                        <circle r="4" fill="#FFD700"/>
                    </g>
                    @if (Expression == "warm" || Expression == "assembly")
                    {
                        <circle cx="140" cy="165" r="5" fill="#FFE0E8" stroke="#FF6B9D" stroke-width="1"/>
                        <circle cx="125" cy="180" r="4" fill="#FFE0E8" stroke="#FF6B9D" stroke-width="1"/>
                    }
                    @if (Expression == "assembly")
                    {
                        <polygon points="100,260 105,268 113,268 107,274 109,282 100,278 91,282 93,274 87,268 95,268" fill="#FFD700"/>
                    }
                    <svg:text x="100" y="230" text-anchor="middle" font-family="serif" font-weight="700" font-size="13" fill="#FFFFFF" letter-spacing="5">T A E</svg:text>
                    <path d="M 18 152 Q 18 140 30 140 L 41 140 Q 53 140 53 152 L 53 338 Q 53 350 41 350 L 30 350 Q 18 350 18 338 Z" fill="url(#tae-limb)"/>
                    <path d="M 147 152 Q 147 140 159 140 L 170 140 Q 182 140 182 152 L 182 338 Q 182 350 170 350 L 159 350 Q 147 350 147 338 Z" fill="url(#tae-limb)"/>
                    <rect x="20"  y="142" width="6" height="200" rx="3" fill="#FFFFFF" opacity="0.2"/>
                    <rect x="149" y="142" width="6" height="200" rx="3" fill="#FFFFFF" opacity="0.2"/>
                    <rect x="18" y="337" width="35" height="20" rx="10" fill="#E04A7A"/>
                    @if (Expression == "private")
                    {
                        <ellipse cx="165" cy="347" rx="10" ry="11" fill="#E5BC97"/>
                    }
                    else
                    {
                        <rect x="147" y="337" width="35" height="20" rx="10" fill="#E04A7A"/>
                    }
                    <path d="M 58 315 Q 58 312 62 312 L 138 312 Q 142 312 142 315 L 142 345 L 58 345 Z" fill="#E04A7A"/>
                    <path d="M 60 348 Q 60 345 64 345 L 91 345 Q 95 345 95 348 L 95 458 Q 95 460 92 460 L 63 460 Q 60 460 60 458 Z" fill="url(#tae-suit)"/>
                    <path d="M 105 348 Q 105 345 109 345 L 136 345 Q 140 345 140 348 L 140 458 Q 140 460 137 460 L 108 460 Q 105 460 105 458 Z" fill="url(#tae-suit)"/>
                </svg>
                break;

            case "iris":
                @switch (Expression)
                {
                    case "bare":
                    case "looking-window":
                    case "looking-at-wren":
                    case "sitting-bench":
                    case "in-clearing":
