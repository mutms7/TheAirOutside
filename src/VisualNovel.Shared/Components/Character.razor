@inject StoryService StoryService

@if (!string.IsNullOrWhiteSpace(Id))
{
    var name = Name;
    var expression = Expression;
    var spec = CharacterSpec.For(name);
    var bare = IsBareExpression(name, expression);
    var shell = $"url(#{SvgId("shell")})";
    var helmet = $"url(#{SvgId("helmet")})";
    var limb = $"url(#{SvgId("limb")})";
    var fabric = $"url(#{SvgId("fabric")})";
    var glass = $"url(#{SvgId("glass")})";

    <div class="character character--@name @(bare ? "character--bare" : "character--suited") character--@name-@expression" @key="@($"{name}-{expression}")">
        <svg class="character__art character__art--@name @(bare ? "character__art--bare" : "character__art--suited")"
             viewBox="0 0 260 520"
             preserveAspectRatio="xMidYMax meet"
             aria-hidden="true"
             style="--char-primary: @spec.Primary; --char-secondary: @spec.Secondary; --char-accent: @spec.Accent; --char-accent-2: @spec.Accent2; --char-dark: @spec.Dark; --char-skin: @spec.Skin; --char-hair: @spec.Hair;">
            <defs>
                <linearGradient id="@SvgId("shell")" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="@spec.Primary" />
                    <stop offset="56%" stop-color="@spec.Mid" />
                    <stop offset="100%" stop-color="@spec.Secondary" />
                </linearGradient>
                <linearGradient id="@SvgId("helmet")" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="@spec.Highlight" />
                    <stop offset="100%" stop-color="@spec.Primary" />
                </linearGradient>
                <linearGradient id="@SvgId("limb")" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="@spec.Secondary" />
                    <stop offset="52%" stop-color="@spec.Primary" />
                    <stop offset="100%" stop-color="@spec.Secondary" />
                </linearGradient>
                <linearGradient id="@SvgId("fabric")" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="@spec.FabricLight" />
                    <stop offset="100%" stop-color="@spec.Fabric" />
                </linearGradient>
                <linearGradient id="@SvgId("glass")" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#30313a" />
                    <stop offset="58%" stop-color="#15161d" />
                    <stop offset="100%" stop-color="#05060a" />
                </linearGradient>
                <radialGradient id="@SvgId("status")" cx="0.45" cy="0.35" r="0.7">
                    <stop offset="0%" stop-color="@spec.Accent" stop-opacity="0.95" />
                    <stop offset="100%" stop-color="@spec.Accent" stop-opacity="0" />
                </radialGradient>
                <filter id="@SvgId("soft-shadow")" x="-30%" y="-30%" width="160%" height="170%">
                    <feDropShadow dx="0" dy="12" stdDeviation="10" flood-color="#000000" flood-opacity="0.22" />
                </filter>
            </defs>

            <ellipse class="character__ground" cx="130" cy="494" rx="92" ry="15" fill="#000" opacity="0.16" />

            @if (bare)
            {
                <g class="character__body character__body--bare" transform="@BareBodyTransform">
                    <path class="character__leg character__leg--left" d="M 83 320 Q 79 370 82 498 L 112 498 Q 114 384 120 320 Z" fill="@spec.FabricDark" />
                    <path class="character__leg character__leg--right" d="M 140 320 Q 145 384 148 498 L 178 498 Q 181 370 176 320 Z" fill="@spec.FabricDark" />
                    <path class="character__shoe" d="M 77 490 Q 95 484 116 490 L 116 504 L 74 504 Q 70 497 77 490 Z" fill="@spec.Dark" opacity="0.92" />
                    <path class="character__shoe" d="M 144 490 Q 163 484 184 490 Q 190 497 184 504 L 144 504 Z" fill="@spec.Dark" opacity="0.92" />

                    <path class="character__torso character__torso--bare" d="M 72 145 Q 130 132 188 145 Q 199 245 190 332 Q 160 346 130 346 Q 100 346 70 332 Q 61 244 72 145 Z" fill="@fabric" />
                    <path class="character__fabric-fold" d="M 88 168 Q 130 158 172 168" stroke="#FFFFFF" stroke-width="4" opacity="0.18" fill="none" stroke-linecap="round" />
                    <path class="character__fabric-fold" d="M 130 148 Q 126 230 132 336" stroke="@spec.FabricDark" stroke-width="1.4" opacity="0.45" fill="none" />

                    @if (name == "iris")
                    {
                        <path d="M 78 151 Q 130 142 182 151 L 177 184 Q 130 174 83 184 Z" fill="@spec.FabricLight" opacity="0.55" />
                    }
                    @if (name == "ozaki")
                    {
                        <rect x="92" y="146" width="76" height="42" fill="@spec.FabricLight" opacity="0.55" />
                        <line x1="108" y1="145" x2="108" y2="333" stroke="@spec.FabricDark" stroke-width="1.2" opacity="0.45" />
                        <line x1="152" y1="145" x2="152" y2="333" stroke="@spec.FabricDark" stroke-width="1.2" opacity="0.45" />
                    }

                    <g class="character__arms character__arms--bare">
                        <g transform="@LeftArmTransform">
                            <path d="M 72 158 Q 45 181 43 250 Q 42 310 52 362" stroke="@spec.Skin" stroke-width="25" stroke-linecap="round" fill="none" />
                            <ellipse cx="52" cy="365" rx="12" ry="14" fill="@spec.Skin" />
                        </g>
                        <g transform="@RightArmTransform">
                            <path d="M 188 158 Q 216 181 217 250 Q 218 310 208 362" stroke="@spec.Skin" stroke-width="25" stroke-linecap="round" fill="none" />
                            <ellipse cx="208" cy="365" rx="12" ry="14" fill="@spec.Skin" />
                        </g>
                    </g>

                    <rect x="119" y="116" width="22" height="34" fill="@spec.Skin" />
                    <g class="character__head character__head--bare" transform="@BareHeadTransform">
                        <ellipse cx="130" cy="79" rx="42" ry="51" fill="@spec.Skin" />
                        <path d="@HairPath(name)" fill="@spec.Hair" />
                        <circle cx="116" cy="@EyeY" r="2.5" fill="#27242a" />
                        <circle cx="144" cy="@EyeY" r="2.5" fill="#27242a" />
                        @if (IsCrying)
                        {
                            <line class="character__tear" x1="115" y1="90" x2="112" y2="112" stroke="#8AB8DC" stroke-width="2.5" stroke-linecap="round" />
                        }
                        @if (name == "iris")
                        {
                            <line x1="99" y1="105" x2="106" y2="110" stroke="#8F684D" stroke-width="1" opacity="0.65" />
                            <line x1="103" y1="96" x2="111" y2="99" stroke="#8F684D" stroke-width="0.8" opacity="0.45" />
                        }
                        <path d="@MouthPath" stroke="#27242a" stroke-width="1.7" fill="none" stroke-linecap="round" />
                    </g>

                    @if (name == "janitor" && expression == "humming")
                    {
                        <g class="character__humming-notes" fill="@spec.Accent" opacity="0.7">
                            <ellipse cx="76" cy="82" rx="4" ry="3" />
                            <rect x="79" y="58" width="2" height="24" />
                            <ellipse cx="190" cy="106" rx="3.5" ry="2.5" />
                            <rect x="193" y="85" width="2" height="22" />
                        </g>
                    }
                </g>
            }
            else
            {
                <g class="character__body character__body--suited" transform="@SuitBodyTransform" filter="@($"url(#{SvgId("soft-shadow")})")">
                    <g class="character__back-glow">
                        <ellipse cx="130" cy="238" rx="86" ry="164" fill="@($"url(#{SvgId("status")})")" opacity="@BackGlowOpacity" />
                    </g>

                    <g class="character__legs">
                        <path d="M 78 315 Q 72 365 76 500 L 116 500 Q 119 386 124 315 Z" fill="@shell" />
                        <path d="M 136 315 Q 141 386 144 500 L 184 500 Q 188 365 182 315 Z" fill="@shell" />
                        <path d="M 84 332 Q 94 326 118 326" stroke="#FFFFFF" stroke-width="4" opacity="0.16" fill="none" stroke-linecap="round" />
                        <path d="M 142 332 Q 154 326 176 326" stroke="#FFFFFF" stroke-width="4" opacity="0.16" fill="none" stroke-linecap="round" />
                    </g>

                    <path class="character__torso" d="M 68 142 Q 130 128 192 142 Q 203 226 197 289 Q 194 320 185 338 Q 158 352 130 352 Q 102 352 75 338 Q 66 320 63 289 Q 57 226 68 142 Z" fill="@shell" />
                    <path class="character__torso-shine" d="M 76 147 Q 130 136 184 147 L 181 165 Q 130 153 79 165 Z" fill="#FFFFFF" opacity="0.2" />
                    <line x1="130" y1="143" x2="130" y2="346" stroke="@spec.Secondary" stroke-width="1.8" opacity="0.62" />
                    <path d="M 84 188 Q 130 174 176 188" stroke="@spec.Accent2" stroke-width="2.2" opacity="0.45" fill="none" stroke-linecap="round" />

                    <g class="character__arms character__arms--suited">
                        <g transform="@LeftArmTransform">
                            <path d="M 64 156 Q 37 186 36 250 Q 35 315 45 370" stroke="@limb" stroke-width="31" stroke-linecap="round" fill="none" />
                            <rect x="25" y="358" width="42" height="28" rx="14" fill="@spec.Secondary" />
                            @if (name == "cael" && expression == "mocking")
                            {
                                <circle class="character__sparkle" cx="20" cy="250" r="7" fill="@spec.Accent" opacity="0.9" />
                            }
                        </g>
                        <g transform="@RightArmTransform">
                            <path d="M 196 156 Q 224 186 224 250 Q 225 315 215 370" stroke="@limb" stroke-width="31" stroke-linecap="round" fill="none" />
                            @if (name == "tae" && expression == "private")
                            {
                                <ellipse cx="215" cy="372" rx="13" ry="15" fill="@spec.Skin" />
                            }
                            else
                            {
                                <rect x="193" y="358" width="42" height="28" rx="14" fill="@spec.Secondary" />
                            }
                        </g>
                    </g>

                    <rect x="104" y="120" width="52" height="28" rx="6" fill="@spec.Secondary" />
                    <g class="character__head character__head--helmet" transform="@HelmetTransform">
                        <ellipse cx="130" cy="74" rx="@HelmetRx" ry="@HelmetRy" fill="@helmet" />
                        <ellipse cx="107" cy="40" rx="25" ry="14" fill="#FFFFFF" opacity="@HelmetShineOpacity" />
                        <path d="M 72 62 Q 130 54 188 62 L 188 88 Q 130 96 72 88 Z" fill="@glass" opacity="0.96" />
                        <path class="character__visor-sheen" d="M 76 63 Q 130 57 184 63 L 184 70 Q 130 64 76 70 Z" fill="#FFFFFF" opacity="0.13" />
                        <rect class="character__status-light" x="80" y="73" width="10" height="7" rx="2" fill="@spec.Accent" opacity="0.9" />
                        @if (name == "iris")
                        {
                            <line x1="94" y1="103" x2="166" y2="103" stroke="@spec.Accent2" stroke-width="3" opacity="0.5" />
                        }
                    </g>

                    <g class="character__decor character__decor--@name">
                        @switch (name)
                        {
                            case "wren":
                                <circle class="character__decal" cx="86" cy="180" r="15" fill="@spec.Primary" stroke="@spec.Secondary" stroke-width="2" />
                                <path class="character__decal-line" d="M 74 177 Q 86 169 98 177" stroke="@spec.Accent" stroke-width="4" fill="none" stroke-linecap="round" />
                                <circle cx="82" cy="174" r="3" fill="#FFFFFF" opacity="0.5" />
                                break;
                            case "tae":
                                <circle class="character__decal" cx="86" cy="183" r="16" fill="@spec.Accent2" />
                                <circle cx="86" cy="183" r="10" fill="@spec.Primary" />
                                <circle cx="86" cy="183" r="4" fill="@spec.Gold" />
                                <circle class="character__sparkle" cx="176" cy="176" r="5" fill="@spec.Accent2" />
                                <circle class="character__sparkle" cx="164" cy="196" r="4" fill="@spec.Accent" />
                                break;
                            case "iris":
                                <rect x="83" y="178" width="94" height="9" rx="4" fill="@spec.Accent2" opacity="0.26" />
                                <circle cx="84" cy="183" r="4" fill="@spec.Dark" opacity="0.24" />
                                break;
                            case "ozaki":
                                <rect x="80" y="177" width="42" height="32" rx="3" fill="@spec.Accent2" opacity="0.62" />
                                <line x1="101" y1="177" x2="101" y2="209" stroke="@spec.Dark" stroke-width="1" opacity="0.45" />
                                @if (expression == "reading")
                                {
                                    <g class="character__book" transform="rotate(-7 92 300)">
                                        <rect x="55" y="276" width="86" height="54" rx="3" fill="#FAF7F1" />
                                        <line x1="98" y1="276" x2="98" y2="330" stroke="@spec.FabricDark" stroke-width="1.2" />
                                        <line x1="66" y1="294" x2="90" y2="294" stroke="@spec.FabricDark" stroke-width="0.8" opacity="0.5" />
                                        <line x1="106" y1="294" x2="130" y2="294" stroke="@spec.FabricDark" stroke-width="0.8" opacity="0.5" />
                                    </g>
                                }
                                break;
                            case "cael":
                                <polygon class="character__decal" points="86,166 97,190 122,192 102,207 109,232 86,219 63,232 70,207 50,192 75,190" fill="@spec.Accent" opacity="0.92" />
                                <circle class="character__sparkle" cx="174" cy="184" r="8" fill="@spec.Accent2" />
                                <circle cx="174" cy="184" r="3" fill="#FFFFFF" opacity="0.75" />
                                break;
                            case "janitor":
                                <rect x="78" y="180" width="25" height="9" rx="2" fill="@spec.Accent2" opacity="0.48" />
                                <rect x="78" y="194" width="46" height="5" rx="2" fill="@spec.Accent2" opacity="0.38" />
                                @if (expression == "with-cart")
                                {
                                    <g class="character__cart" transform="translate(188 310)">
                                        <rect x="0" y="0" width="48" height="62" rx="4" fill="@spec.Accent2" opacity="0.88" />
                                        <rect x="4" y="6" width="40" height="10" rx="2" fill="#FFFFFF" opacity="0.22" />
                                        <line x1="0" y1="0" x2="-28" y2="-70" stroke="@spec.Accent2" stroke-width="5" stroke-linecap="round" />
                                        <circle cx="10" cy="68" r="6" fill="#17171b" />
                                        <circle cx="40" cy="68" r="6" fill="#17171b" />
                                    </g>
                                }
                                @if (expression == "humming")
                                {
                                    <g class="character__humming-notes" fill="@spec.Accent2" opacity="0.68">
                                        <ellipse cx="74" cy="77" rx="4" ry="3" />
                                        <rect x="77" y="53" width="2" height="24" />
                                        <ellipse cx="188" cy="96" rx="3.5" ry="2.5" />
                                        <rect x="191" y="74" width="2" height="23" />
                                    </g>
                                }
                                break;
                        }
                    </g>

                    <svg:text class="character__suit-name" x="130" y="256" text-anchor="middle" font-family="serif" font-weight="700" font-size="@SuitFontSize" fill="@spec.NameColor" letter-spacing="@SuitLetterSpacing">@SuitName</svg:text>
                </g>
            }
        </svg>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private string Name => Id.Split(' ', 2)[0].ToLowerInvariant();
    private string Expression => Id.Contains(' ') ? Id.Split(' ', 2)[1].ToLowerInvariant() : "neutral";

    private string SvgId(string suffix) => $"char-{Name}-{suffix}";

    private bool IsCrying => Expression.Contains("cry", StringComparison.OrdinalIgnoreCase);
    private bool IsSoft => Expression is "warm" or "private" or "looking-window" or "looking-at-wren" or "sitting-bench" or "in-clearing" or "humming";
    private bool IsTroubled => Expression is "troubled" or "bare-cry";

    private string EyeY => IsTroubled ? "84" : "78";
    private string MouthPath => IsCrying
        ? "M 118 100 Q 130 96 142 100"
        : IsSoft ? "M 117 99 Q 130 105 143 99" : "M 118 99 Q 130 101 142 99";

    private string SuitBodyTransform => Expression switch
    {
        "troubled" => "translate(4 8) rotate(1.4 130 270)",
        "mocking" => "translate(-10 0) rotate(-2 130 270)",
        "assembly" => "translate(0 -3)",
        _ => "translate(0 0)"
    };

    private string BareBodyTransform => Expression switch
    {
        "dancing" => "translate(0 -4) rotate(-4 130 330)",
        "bare-cry" => "translate(2 8)",
        "looking-at-wren" => "translate(3 0)",
        "in-clearing" => "translate(0 -6)",
        _ => "translate(0 0)"
    };

    private string HelmetTransform => Expression switch
    {
        "troubled" => "translate(4 7) rotate(2 130 75)",
        "mocking" => "rotate(-3 130 75)",
        _ => "translate(0 0)"
    };

    private string BareHeadTransform => Expression switch
    {
        "bare-cry" => "translate(1 4)",
        "looking-window" => "translate(-3 0)",
        "looking-at-wren" => "translate(4 0)",
        _ => "translate(0 0)"
    };

    private string LeftArmTransform => (Name, Expression) switch
    {
        ("cael", "mocking") => "rotate(-34 64 156) translate(-22 -18)",
        ("ozaki", "dancing") => "rotate(-22 64 156) translate(-12 -18)",
        _ => "translate(0 0)"
    };

    private string RightArmTransform => (Name, Expression) switch
    {
        ("ozaki", "dancing") => "rotate(18 196 156) translate(12 -8)",
        ("tae", "private") => "rotate(7 196 156)",
        _ => "translate(0 0)"
    };

    private string HelmetRx => Name == "cael" ? "68" : Name == "janitor" ? "58" : "62";
    private string HelmetRy => Name == "cael" ? "66" : "64";
    private string HelmetShineOpacity => Name == "cael" ? "0.30" : Name == "iris" ? "0.12" : "0.20";
    private string BackGlowOpacity => Name == "iris" ? "0.10" : Name == "janitor" ? "0.12" : "0.22";
    private string SuitFontSize => Name == "wren" ? "12" : "13";
    private string SuitLetterSpacing => Name == "wren" ? "4" : "5";

    private string SuitName
    {
        get
        {
            if (Name != "wren") return CharacterSpec.For(Name).SuitLetters;
            var n = StoryService.GetVar("protagonist_name");
            return SpacedName(string.IsNullOrWhiteSpace(n) ? "WREN" : n, 8);
        }
    }

    private static bool IsBareExpression(string name, string expression) => expression switch
    {
        "bare" or "bare-cry" or "dancing" or "looking-window" or "looking-at-wren" or "sitting-bench" or "in-clearing" => true,
        _ => false
    };

    private static string HairPath(string name) => name switch
    {
        "wren" => "M 88 69 Q 130 23 172 69 Q 168 38 130 34 Q 92 38 88 69 Z",
        "tae" => "M 86 68 Q 130 26 174 68 Q 170 118 160 138 Q 148 108 130 101 Q 112 108 100 138 Q 90 118 86 68 Z",
        "iris" => "M 88 64 Q 130 22 172 64 L 176 132 Q 166 107 164 88 Q 130 104 96 88 Q 94 107 84 132 Z",
        "ozaki" => "M 90 68 Q 130 42 170 68 Q 168 54 130 50 Q 92 54 90 68 Z",
        "cael" => "M 88 68 Q 106 36 130 42 Q 154 34 174 68 Q 150 56 130 62 Q 112 56 88 68 Z",
        "janitor" => "M 92 68 Q 130 45 168 68 Q 160 52 130 54 Q 100 52 92 68 Z",
        _ => "M 88 68 Q 130 34 172 68 Q 168 44 130 40 Q 92 44 88 68 Z"
    };

    private static string SpacedName(string n, int maxChars)
    {
        var clean = new string(n.ToUpperInvariant().Where(char.IsLetterOrDigit).Take(maxChars).ToArray());
        return string.Join(" ", clean.ToCharArray());
    }

    private sealed record CharacterSpec(
        string Primary,
        string Mid,
        string Secondary,
        string Highlight,
        string Accent,
        string Accent2,
        string Gold,
        string Dark,
        string Skin,
        string Hair,
        string Fabric,
        string FabricLight,
        string FabricDark,
        string NameColor,
        string SuitLetters)
    {
        public static CharacterSpec For(string name) => name switch
        {
            "wren" => new("#F5B68C", "#EEA875", "#D98F5E", "#FFD0A8", "#A8E6CF", "#FFF1CD", "#FFD24A", "#6A4028", "#E5BC97", "#3A2818", "#D8C8B8", "#EFE2D2", "#5C5447", "#8A4C2A", "W R E N"),
            "tae" => new("#FF6B9D", "#F05B8B", "#D84473", "#FFA0C0", "#FFD1DC", "#FFE0E8", "#FFD24A", "#79314E", "#D9A27F", "#322033", "#7B516E", "#A86591", "#3A2735", "#FFFFFF", "T A E"),
            "iris" => new("#B8B0A8", "#AFA69D", "#8F877E", "#D3CCC4", "#E8E4DA", "#7A7A6A", "#C9B080", "#5C5C54", "#D9B89C", "#2A2018", "#777766", "#8A8A78", "#3F3F38", "#5C5C54", "I R I S"),
            "ozaki" => new("#6B6855", "#5D5A48", "#444232", "#827F68", "#E8E0D2", "#A89580", "#C9B080", "#2F2D21", "#C9A685", "#1F1A14", "#E8E0D2", "#F2EBDC", "#3A2E20", "#1F1D10", "O Z A K I"),
            "cael" => new("#FFD24A", "#F5C431", "#C99820", "#FFE89C", "#FF6B9D", "#FF8C5C", "#FFE082", "#8A5F08", "#C79A72", "#3A2818", "#6E5936", "#8C7144", "#3A2E20", "#8A5F08", "C A E L"),
            "janitor" => new("#8E8E8A", "#7B7B76", "#62625E", "#A6A6A0", "#D4D4CA", "#A89580", "#C9B080", "#3D3D3A", "#BFA08A", "#3A342E", "#77776E", "#8D8D82", "#3F3F3A", "#3D3D3A", "SERVICE"),
            _ => new("#CCCCCC", "#BBBBBB", "#999999", "#DDDDDD", "#FFFFFF", "#AAAAAA", "#CCCC99", "#555555", "#D9B89C", "#2A2018", "#888888", "#AAAAAA", "#444444", "#555555", "")
        };
    }
}
