@if (!string.IsNullOrEmpty(Id))
{
    <div class="motif motif--@Id">
        @switch (Id)
        {
            case "ant-hill-building":
                <svg class="motif__icon" viewBox="0 0 120 90" aria-label="ant hill, building">
                    <ellipse cx="60" cy="80" rx="55" ry="6" fill="#3A2E20" opacity="0.5"/>
                    <polygon points="20,80 60,30 100,80" fill="#A89580"/>
                    <polygon points="32,80 60,42 88,80" fill="#9B8973"/>
                    <polygon points="44,80 60,55 76,80" fill="#8B7762"/>
                    <ellipse cx="58" cy="78" rx="2" ry="1.5" fill="#2A1F14"/>
                    <ellipse cx="62" cy="76" rx="2" ry="1.5" fill="#2A1F14"/>
                    <ellipse cx="68" cy="64" rx="2" ry="1.5" fill="#2A1F14"/>
                    <ellipse cx="50" cy="70" rx="2" ry="1.5" fill="#2A1F14"/>
                </svg>
                break;

            case "ant-hill-crushed":
                <svg class="motif__icon" viewBox="0 0 120 90" aria-label="ant hill, crushed">
                    <ellipse cx="60" cy="80" rx="55" ry="6" fill="#3A2E20" opacity="0.5"/>
                    <polygon points="20,80 30,55 50,68 60,40 70,68 90,55 100,80" fill="#A89580"/>
                    <polygon points="32,80 40,62 55,72 60,52 65,72 80,62 88,80" fill="#9B8973"/>
                    <path d="M 25 76 Q 60 60 95 76" stroke="#5C5C5C" stroke-width="4" fill="none" opacity="0.8"/>
                    <ellipse cx="42" cy="74" rx="2" ry="1.5" fill="#2A1F14"/>
                    <ellipse cx="48" cy="68" rx="2" ry="1.5" fill="#2A1F14"/>
                    <ellipse cx="72" cy="68" rx="2" ry="1.5" fill="#2A1F14"/>
                    <ellipse cx="78" cy="74" rx="2" ry="1.5" fill="#2A1F14"/>
                </svg>
                break;

            case "ant-hill-eye-level":
                <svg class="motif__icon" viewBox="0 0 120 90" aria-label="single ant carrying grain">
                    <line x1="0" y1="78" x2="120" y2="78" stroke="#A89580" stroke-width="1"/>
                    <ellipse cx="56" cy="60" rx="4" ry="3" fill="#2A1F14"/>
                    <ellipse cx="62" cy="60" rx="5" ry="3.5" fill="#2A1F14"/>
                    <ellipse cx="69" cy="60" rx="4" ry="3" fill="#2A1F14"/>
                    <line x1="58" y1="60" x2="55" y2="54" stroke="#2A1F14" stroke-width="0.8"/>
                    <line x1="58" y1="60" x2="55" y2="66" stroke="#2A1F14" stroke-width="0.8"/>
                    <line x1="62" y1="60" x2="62" y2="53" stroke="#2A1F14" stroke-width="0.8"/>
                    <line x1="62" y1="60" x2="62" y2="68" stroke="#2A1F14" stroke-width="0.8"/>
                    <line x1="67" y1="60" x2="70" y2="54" stroke="#2A1F14" stroke-width="0.8"/>
                    <line x1="67" y1="60" x2="70" y2="66" stroke="#2A1F14" stroke-width="0.8"/>
                    <line x1="53" y1="60" x2="48" y2="55" stroke="#2A1F14" stroke-width="0.8"/>
                    <line x1="71" y1="60" x2="76" y2="55" stroke="#2A1F14" stroke-width="0.8"/>
                    <ellipse cx="55" cy="48" rx="9" ry="7" fill="#C9B080"/>
                    <ellipse cx="55" cy="48" rx="5" ry="4" fill="#A89060"/>
                </svg>
                break;

            case "sticker-applied-preview":
            case "sticker-applied":
                <svg class="motif__icon" viewBox="0 0 90 90" aria-label="peach sticker with mint accent">
                    <circle cx="45" cy="45" r="32" fill="#F5B68C" stroke="#D89B70" stroke-width="2"/>
                    <circle cx="45" cy="45" r="28" fill="#F5B68C"/>
                    <path d="M 30 40 Q 45 32 60 40" stroke="#A8E6CF" stroke-width="5" fill="none" stroke-linecap="round"/>
                    <circle cx="45" cy="45" r="32" fill="none" stroke="#FFFFFF" stroke-width="1" opacity="0.5"/>
                </svg>
                break;

            case "sticker-peeling":
                <svg class="motif__icon" viewBox="0 0 90 90" aria-label="peach sticker, peeling at corner">
                    <circle cx="45" cy="45" r="32" fill="#F5B68C" stroke="#D89B70" stroke-width="2"/>
                    <path d="M 30 40 Q 45 32 60 40" stroke="#A8E6CF" stroke-width="5" fill="none" stroke-linecap="round"/>
                    <path d="M 70 28 Q 75 22 80 18 L 78 32 Q 74 30 70 28 Z" fill="#F0DBC8" stroke="#D89B70" stroke-width="1"/>
                </svg>
                break;

            case "sticker-in-palm":
                <svg class="motif__icon" viewBox="0 0 120 90" aria-label="sticker in a bare hand">
                    <path d="M 20 60 Q 18 40 30 38 Q 60 35 90 38 Q 102 40 100 60 L 100 80 L 20 80 Z" fill="#D9B89C"/>
                    <path d="M 30 60 Q 35 50 50 50" stroke="#9B7050" stroke-width="0.8" fill="none"/>
                    <path d="M 45 65 Q 55 58 70 60" stroke="#9B7050" stroke-width="0.8" fill="none"/>
                    <circle cx="60" cy="50" r="18" fill="#F5B68C" stroke="#D89B70" stroke-width="1.5"/>
                    <path d="M 50 47 Q 60 43 70 47" stroke="#A8E6CF" stroke-width="3" fill="none" stroke-linecap="round"/>
                </svg>
                break;

            case "sticker-tae-drawer":
                <svg class="motif__icon" viewBox="0 0 120 90" aria-label="sticker in Tae's drawer">
                    <rect x="10" y="20" width="100" height="60" fill="#3F2A3A" stroke="#FF6B9D" stroke-width="1"/>
                    <rect x="15" y="25" width="90" height="50" fill="#2A1B27"/>
                    <rect x="30" y="35" width="60" height="30" fill="#F0DBC8" stroke="#D89B70" stroke-width="0.8" opacity="0.85" transform="rotate(-3 60 50)"/>
                    <circle cx="60" cy="50" r="14" fill="#F5B68C" stroke="#D89B70" stroke-width="1.5" transform="rotate(-3 60 50)"/>
                    <path d="M 53 47 Q 60 43 67 47" stroke="#A8E6CF" stroke-width="2.5" fill="none" stroke-linecap="round" transform="rotate(-3 60 50)"/>
                    <line x1="30" y1="80" x2="90" y2="80" stroke="#FF6B9D" stroke-width="2"/>
                </svg>
                break;

            case "sticker-drawer":
                <svg class="motif__icon" viewBox="0 0 120 90" aria-label="sticker in a desk drawer">
                    <rect x="10" y="25" width="100" height="55" fill="#A89580" stroke="#8B7762" stroke-width="1.5"/>
                    <rect x="15" y="30" width="90" height="45" fill="#9B8973"/>
                    <circle cx="60" cy="55" r="16" fill="#F5B68C" stroke="#D89B70" stroke-width="1.5"/>
                    <path d="M 50 52 Q 60 47 70 52" stroke="#A8E6CF" stroke-width="3" fill="none" stroke-linecap="round"/>
                    <rect x="50" y="78" width="20" height="4" fill="#A89580"/>
                </svg>
                break;

            case "sticker-window":
                <svg class="motif__icon" viewBox="0 0 120 90" aria-label="sticker stuck to a brick window">
                    <rect x="10" y="10" width="100" height="70" fill="#9B8973"/>
                    <g stroke="#7A6957" stroke-width="0.8" fill="none">
                        <line x1="10" y1="25" x2="110" y2="25"/>
                        <line x1="10" y1="45" x2="110" y2="45"/>
                        <line x1="10" y1="65" x2="110" y2="65"/>
                        <line x1="40" y1="10" x2="40" y2="25"/>
                        <line x1="80" y1="10" x2="80" y2="25"/>
                        <line x1="20" y1="25" x2="20" y2="45"/>
                        <line x1="60" y1="25" x2="60" y2="45"/>
                        <line x1="100" y1="25" x2="100" y2="45"/>
                    </g>
                    <circle cx="50" cy="55" r="18" fill="#F5B68C" stroke="#D89B70" stroke-width="2"/>
                    <path d="M 38 51 Q 50 44 62 51" stroke="#A8E6CF" stroke-width="3" fill="none" stroke-linecap="round"/>
                </svg>
                break;

            case "sticker-reapplied":
                <svg class="motif__icon" viewBox="0 0 90 90" aria-label="sticker reapplied">
                    <circle cx="45" cy="45" r="32" fill="#F5B68C" stroke="#D89B70" stroke-width="2"/>
                    <path d="M 30 40 Q 45 32 60 40" stroke="#A8E6CF" stroke-width="5" fill="none" stroke-linecap="round"/>
                    <circle cx="45" cy="45" r="32" fill="none" stroke="#FFFFFF" stroke-width="1" opacity="0.5"/>
                    <circle cx="78" cy="14" r="4" fill="#A8E6CF" opacity="0.6"/>
                </svg>
                break;

            case "rain-window":
                <svg class="motif__icon" viewBox="0 0 90 90" aria-label="rain on a windowpane">
                    <rect x="8" y="8" width="74" height="74" fill="#D9E5EE" stroke="#A1AEBC" stroke-width="2"/>
                    <line x1="45" y1="8" x2="45" y2="82" stroke="#A1AEBC" stroke-width="1.5"/>
                    <line x1="8" y1="45" x2="82" y2="45" stroke="#A1AEBC" stroke-width="1.5"/>
                    <g stroke="#5C7894" stroke-width="1.5" stroke-linecap="round">
                        <line x1="20" y1="18" x2="18" y2="32"/>
                        <line x1="30" y1="24" x2="28" y2="38"/>
                        <line x1="40" y1="16" x2="38" y2="30"/>
                        <line x1="55" y1="22" x2="53" y2="36"/>
                        <line x1="65" y1="18" x2="63" y2="32"/>
                        <line x1="74" y1="24" x2="72" y2="38"/>
                        <line x1="18" y1="50" x2="16" y2="64"/>
                        <line x1="34" y1="54" x2="32" y2="68"/>
                        <line x1="52" y1="50" x2="50" y2="64"/>
                        <line x1="68" y1="56" x2="66" y2="70"/>
                    </g>
                </svg>
                break;

            case "rain-bare":
                <svg class="motif__icon" viewBox="0 0 120 90" aria-label="rain on bare skin">
                    <path d="M 10 50 Q 20 40 40 42 Q 60 38 80 42 Q 100 40 110 50 L 110 90 L 10 90 Z" fill="#D9B89C"/>
                    <path d="M 30 55 Q 50 50 70 55" stroke="#9B7050" stroke-width="0.6" fill="none"/>
                    <g stroke="#5C7894" stroke-width="2" stroke-linecap="round">
                        <line x1="20" y1="5" x2="22" y2="20"/>
                        <line x1="32" y1="2" x2="34" y2="18"/>
                        <line x1="46" y1="8" x2="48" y2="22"/>
                        <line x1="58" y1="3" x2="60" y2="18"/>
                        <line x1="72" y1="6" x2="74" y2="22"/>
                        <line x1="86" y1="2" x2="88" y2="18"/>
                        <line x1="100" y1="8" x2="102" y2="22"/>
                    </g>
                    <g fill="#88A7C9">
                        <ellipse cx="35" cy="45" rx="1.5" ry="2"/>
                        <ellipse cx="55" cy="48" rx="1.5" ry="2"/>
                        <ellipse cx="75" cy="46" rx="1.5" ry="2"/>
                        <ellipse cx="50" cy="60" rx="1.2" ry="1.6"/>
                        <ellipse cx="70" cy="58" rx="1.2" ry="1.6"/>
                    </g>
                </svg>
                break;

            case "song-foreshadow":
            case "song-janitor":
            case "song-grandma":
            case "song-hummed-aloud":
            case "song-final":
                <svg class="motif__icon" viewBox="0 0 120 90" aria-label="a hummed song">
                    <g fill="@(SongColor(Id))" opacity="@(SongOpacity(Id))">
                        <ellipse cx="22" cy="55" rx="8" ry="6"/>
                        <rect x="29" y="22" width="3" height="36"/>
                        <ellipse cx="52" cy="48" rx="8" ry="6"/>
                        <rect x="59" y="15" width="3" height="36"/>
                        <ellipse cx="84" cy="58" rx="8" ry="6"/>
                        <rect x="91" y="25" width="3" height="36"/>
                        <path d="M 32 22 Q 50 14 62 15" stroke="@(SongColor(Id))" stroke-width="3" fill="none"/>
                    </g>
                    @if (Id == "song-hummed-aloud" || Id == "song-final")
                    {
                        <g fill="@(SongColor(Id))" opacity="0.45">
                            <circle cx="106" cy="20" r="3"/>
                            <circle cx="112" cy="30" r="2"/>
                            <circle cx="104" cy="42" r="2"/>
                        </g>
                    }
                </svg>
                break;

            default:
                <div class="motif__label">[@Id]</div>
                break;
        }
        <div class="motif__label">[@Id]</div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private static string SongColor(string id) => id switch
    {
        "song-foreshadow"     => "#8E8E8A",
        "song-janitor"        => "#5C5C58",
        "song-grandma"        => "#A89580",
        "song-hummed-aloud"   => "#F5B68C",
        "song-final"          => "#D89B70",
        _                     => "#8E8E8A",
    };

    private static string SongOpacity(string id) => id switch
    {
        "song-foreshadow"     => "0.55",
        _                     => "0.85",
    };
}
