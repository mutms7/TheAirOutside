@if (!string.IsNullOrEmpty(Id))
{
    <div class="motif motif--@Id">
        @if (Id.StartsWith("ant"))
        {
            <svg class="motif__icon" viewBox="0 0 40 40" aria-label="ant motif">
                <ellipse cx="14" cy="20" rx="3" ry="3" fill="#3A3A3A"/>
                <ellipse cx="20" cy="20" rx="4" ry="3.5" fill="#3A3A3A"/>
                <ellipse cx="26" cy="20" rx="3" ry="3" fill="#3A3A3A"/>
                <line x1="14" y1="20" x2="11" y2="14" stroke="#3A3A3A" stroke-width="1"/>
                <line x1="14" y1="20" x2="11" y2="26" stroke="#3A3A3A" stroke-width="1"/>
                <line x1="20" y1="20" x2="20" y2="13" stroke="#3A3A3A" stroke-width="1"/>
                <line x1="20" y1="20" x2="20" y2="27" stroke="#3A3A3A" stroke-width="1"/>
                <line x1="26" y1="20" x2="29" y2="14" stroke="#3A3A3A" stroke-width="1"/>
                <line x1="26" y1="20" x2="29" y2="26" stroke="#3A3A3A" stroke-width="1"/>
            </svg>
        }
        else if (Id.StartsWith("rain"))
        {
            <svg class="motif__icon" viewBox="0 0 24 24" aria-label="rain motif">
                <path d="M12 2 C7 9 4 13 4 17 a8 8 0 0 0 16 0 c0 -4 -3 -8 -8 -15z" fill="#5C7894"/>
            </svg>
        }
        <div class="motif__label">[@Id]</div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";
}
