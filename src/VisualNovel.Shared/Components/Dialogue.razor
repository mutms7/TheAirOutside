<div class="dialogue">
    @if (!string.IsNullOrEmpty(Speaker) && SpeakerKey != "hud")
    {
        <div class="dialogue__speaker dialogue__speaker--@SpeakerKey">@DisplaySpeaker</div>
    }
    @if (SpeakerKey == "hud" && !string.IsNullOrEmpty(Text))
    {
        <div class="dialogue__hud-label">▮ SUIT</div>
    }
    @if (!string.IsNullOrEmpty(Text))
    {
        <div class="dialogue__text dialogue__text--@SpeakerKey">@Text</div>
    }
</div>

@code {
    [Parameter] public string Speaker { get; set; } = "";
    [Parameter] public string Text { get; set; } = "";

    private string SpeakerKey =>
        string.IsNullOrEmpty(Speaker) ? "narration" : Speaker.ToLowerInvariant();

    private string DisplaySpeaker =>
        string.IsNullOrEmpty(Speaker) ? "" : char.ToUpperInvariant(Speaker[0]) + Speaker[1..];
}
