@using System.Timers
@using Microsoft.JSInterop
@inject StoryService Story
@inject SettingsService SettingsSvc
@inject SaveService SaveSvc
@inject MusicService MusicSvc
@inject IJSRuntime JS
@implements IDisposable

@if (!Story.IsPrologueDone && Story.Scene == 0)
{
    <NameInput />
}
else if (_showPrologueReplay)
{
    <NameInput IsReplay="true" OnClose="ClosePrologueReplay" />
}

<div @ref="_stageRef"
     class="stage voice-@Story.Voice pacing-@Story.Pacing scene-@Story.Scene background-@Story.Background audio-@Story.Audio theme-@SettingsSvc.Current.Theme @(SettingsSvc.Current.ReduceMotion ? "reduce-motion" : "") @(Story.IsClimaxPause ? "climax-pause" : "") @(IsDarkBackground ? "bg-dark" : "bg-light") @(_showPauseMenu ? "stage--menu-open" : "")"
     style="--text-size-mult: @(SettingsSvc.Current.TextSize.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)); @(Story.IsPrologueDone ? "" : "visibility: hidden;")"
     tabindex="0"
     @onclick="OnStageClick">

    @if (!Story.IsClimaxPause)
    {
        <div class="stage__look-layer stage__look-layer--back" aria-hidden="true">
            <Background Id="@Story.Background" Scene="@Story.Scene" />
            <div class="stage__atmosphere stage__atmosphere--@Story.Background"></div>
        </div>
        <div class="stage__look-layer stage__look-layer--mid">
            <MotionScene />
            <ObjectFocus />
            @if (ShowLegacyMotif)
            {
                <Motif Id="@Story.Motif" />
            }
            @if (ShowLegacySpotArt)
            {
                <SpotArt Id="@Story.Art" />
            }
        </div>
    }

    @if (Story.IsClimaxPause)
    {
        <div class="climax">
            <div class="climax__line">@Story.CurrentText</div>
        </div>
    }
    else if (!Story.IsAtChoice && !Story.IsEnded)
    {
        <div class="dialogue-wrap @(_transitioning ? "dialogue-wrap--out" : "")"
             style="--fade-ms: @SettingsSvc.Current.TextFadeMs.ToString("0", System.Globalization.CultureInfo.InvariantCulture)ms;">
            <Dialogue Speaker="@Story.Speaker" Text="@Story.CurrentText" />
        </div>
    }

    @if (Story.IsAtChoice)
    {
        <div class="stage__choices" @onclick:stopPropagation="true">
            @for (var i = 0; i < Story.CurrentChoices.Count; i++)
            {
                var idx = i;
                <button class="stage__choice" @onclick="() => OnChoice(idx)">
                    @Story.CurrentChoices[idx].text
                </button>
            }
        </div>
    }

    @if (Story.IsEnded)
    {
        <div class="stage__ending">
            @if (!string.IsNullOrEmpty(Story.EndingTitle))
            {
                <div class="stage__ending-eyebrow">An Ending</div>
                <div class="stage__ending-title">@Story.EndingTitle</div>
                <button class="stage__ending-btn" @onclick="OnPlayAgain" @onclick:stopPropagation="true">
                    Play Again
                </button>
            }
            else
            {
                <div>— end of the prototype —</div>
            }
        </div>
    }

    <TopBar OnOpen="OpenPanel" />

    @if (_showPauseMenu)
    {
        <div class="pause-menu-overlay" @onclick="ClosePauseMenu" @onclick:stopPropagation="true">
            <section class="pause-menu" @onclick:stopPropagation="true" aria-label="Game menu">
                <div class="pause-menu__eyebrow">Paused</div>
                <h2 class="pause-menu__title">Menu</h2>
                <div class="pause-menu__actions">
                    <button class="pause-menu__btn pause-menu__btn--primary" @onclick="ClosePauseMenu">Continue</button>
                    <button class="pause-menu__btn" @onclick="() => OpenMenuPanel(TopBar.Panel.Settings)">Settings</button>
                    <button class="pause-menu__btn" @onclick="() => OpenMenuPanel(TopBar.Panel.Map)">Story Map</button>
                    <button class="pause-menu__btn" @onclick="() => OpenMenuPanel(TopBar.Panel.Backlog)">History</button>
                    <button class="pause-menu__btn pause-menu__btn--exit" @onclick="ExitApplication">Exit</button>
                </div>
            </section>
        </div>
    }

    @if (_openPanel == TopBar.Panel.Map)
    {
        <StoryMap OnJump="HandleJump" OnPrologue="OpenPrologueReplay" OnCloseCallback="ClosePanel" />
    }
    else if (_openPanel != TopBar.Panel.None)
    {
        <div class="panel-overlay" @onclick="ClosePanel" @onclick:stopPropagation="true">
            <aside class="panel" @onclick:stopPropagation="true">
                <button class="panel__close" @onclick="ClosePanel" aria-label="Close">×</button>
                @switch (_openPanel)
                {
                    case TopBar.Panel.Settings:
                        <Settings />
                        break;
                    case TopBar.Panel.Backlog:
                        <Backlog />
                        break;
                }
            </aside>
        </div>
    }

    @if (_pendingJump is not null)
    {
        <div class="modal-overlay" @onclick:stopPropagation="true">
            <div class="modal">
                <h3 class="modal__title">Skip ahead?</h3>
                <p class="modal__body">
                    The recommended way to enjoy <em>The Air Outside</em> is from beginning to end.
                </p>
                <p class="modal__body">
                    You're about to jump forward to <strong>Scene @_pendingJump.Id — @_pendingJump.Title</strong>. Earlier scenes set context and gate choices that won't be in place; the variant logic will fall back to defaults.
                </p>
                <p class="modal__hint">
                    Jumping to a scene you've already read or back to where you left off is safe — that's only flagged here because you're moving forward in the story.
                </p>
                <div class="modal__actions">
                    <button class="modal__btn modal__btn--ghost" @onclick="CancelJump">Stay here</button>
                    <button class="modal__btn modal__btn--primary" @onclick="ConfirmJump">Jump anyway</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private static readonly HashSet<string> DarkBackgrounds = new(StringComparer.OrdinalIgnoreCase)
    {
        "bedroom-night", "hallway-night", "taes-room",
        "field-night", "field-clearing", "nurse-office-night"
    };

    private bool IsDarkBackground
    {
        get
        {
            if (SettingsSvc.Current.Theme == "dark") return true;
            return !string.IsNullOrEmpty(Story.Background) && DarkBackgrounds.Contains(Story.Background);
        }
    }

    private Timer? _autoTimer;
    private bool _transitioning;
    private TopBar.Panel _openPanel = TopBar.Panel.None;
    private SceneInfo? _pendingJump;
    private bool _showPrologueReplay;
    private bool _showPauseMenu;
    private int _lastMoodScene = -1;
    private ElementReference _stageRef;
    private DotNetObjectReference<Stage>? _inputRef;

    private static readonly HashSet<string> MotionHandledMotifs = new(StringComparer.OrdinalIgnoreCase)
    {
        "ant-hill-building", "ant-hill-crushed", "ant-hill-eye-level",
        "song-grandma", "rain-window", "rain-bare"
    };

    private static readonly HashSet<string> MotionHandledArt = new(StringComparer.OrdinalIgnoreCase)
    {
        "dinosaur-kid", "dexterity-positions", "ozaki-stepping-out",
        "bare-hands-clasp", "tae-from-doorway", "service-class-woman"
    };

    private static readonly HashSet<string> FocusHandledArt = new(StringComparer.OrdinalIgnoreCase)
    {
        "boot-up-hud", "dinosaur-kid", "tae-ping",
        "tae-coral-decoration", "dexterity-positions", "chest-seal-crack",
        "corridor-windows", "iris-bare-hand", "literature-book",
        "basin-passage", "be-more-honest-worksheet", "wren-bedside-drawer",
        "tae-strawberry-water", "fallen-tree-trunk", "wren-window-open",
        "bare-hands-clasp", "corner-brick-window"
    };

    private bool ShowLegacyMotif =>
        !string.IsNullOrWhiteSpace(Story.Motif)
        && !MotionHandledMotifs.Contains(Story.Motif)
        && !IsFocusHandledMotif(Story.Motif);

    private bool ShowLegacySpotArt =>
        !string.IsNullOrWhiteSpace(Story.Art)
        && !MotionHandledArt.Contains(Story.Art)
        && !FocusHandledArt.Contains(Story.Art);

    private static bool IsFocusHandledMotif(string motif) =>
        motif.StartsWith("ant-hill", StringComparison.OrdinalIgnoreCase)
        || motif.StartsWith("sticker", StringComparison.OrdinalIgnoreCase)
        || motif.StartsWith("rain", StringComparison.OrdinalIgnoreCase)
        || motif.StartsWith("song", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        Story.StateChanged += OnStateChanged;
        Story.StateChanged += OnProgressChanged;
        SettingsSvc.Changed += OnSettingsChanged;
        ResetTimer();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _inputRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("visualNovelInput.bind", _stageRef, _inputRef);
    }

    private async void OnProgressChanged()
    {
        if (Story.IsPrologueDone)
        {
            await SaveSvc.SaveAsync(
                Story.VisitedScenes,
                Story.Scene,
                Story.IsPrologueDone,
                Story.GetVar("protagonist_name"));
        }

        if (Story.Scene != _lastMoodScene)
        {
            _lastMoodScene = Story.Scene;
            await MusicSvc.SetSceneMoodAsync(Story.Scene);
        }

        if (!string.IsNullOrWhiteSpace(Story.CurrentAudioCue))
        {
            await MusicSvc.PlayCueAsync(Story.CurrentAudioCue, Story.Scene);
        }

        foreach (var sfx in Story.CurrentSfx)
        {
            await MusicSvc.PlaySfxAsync(sfx);
        }
    }

    private void OnStateChanged()
    {
        InvokeAsync(() =>
        {
            ResetTimer();
            StateHasChanged();
        });
    }

    private void OnSettingsChanged() => InvokeAsync(() =>
    {
        ResetTimer();
        StateHasChanged();
    });

    private void ResetTimer()
    {
        _autoTimer?.Stop();
        _autoTimer?.Dispose();
        _autoTimer = null;

        if (!Story.CanAdvance) return;
        if (Story.IsClimaxPause) return;
        if (!SettingsSvc.Current.AutoAdvance) return;
        if (_openPanel != TopBar.Panel.None) return;
        if (_showPauseMenu) return;

        var baseMs = SettingsSvc.Current.AutoAdvanceDelay * 1000;
        var ms = Story.Pacing == "slow" ? baseMs * 1.7 : baseMs;
        _autoTimer = new Timer(ms) { AutoReset = false };
        _autoTimer.Elapsed += async (_, _) =>
        {
            await InvokeAsync(async () =>
            {
                if (Story.CanAdvance && !Story.IsClimaxPause && _openPanel == TopBar.Panel.None && !_showPauseMenu)
                    await TransitionAdvance();
            });
        };
        _autoTimer.Start();
    }

    private async Task OnStageClick()
    {
        await AdvanceRequested();
    }

    [JSInvokable]
    public async Task AdvanceFromInput()
    {
        await AdvanceRequested();
    }

    [JSInvokable]
    public Task BackFromInput()
    {
        if (!Story.IsPrologueDone) return Task.CompletedTask;
        if (_showPauseMenu || _openPanel != TopBar.Panel.None || _pendingJump is not null || _showPrologueReplay) return Task.CompletedTask;
        if (_transitioning) return Task.CompletedTask;

        Story.GoBack();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task ToggleMenuFromInput()
    {
        if (!Story.IsPrologueDone) return Task.CompletedTask;

        if (_showPauseMenu)
        {
            ClosePauseMenu();
        }
        else
        {
            OpenPauseMenu();
        }

        return Task.CompletedTask;
    }

    private async Task AdvanceRequested()
    {
        if (!Story.IsPrologueDone) return;
        if (_openPanel != TopBar.Panel.None) return;
        if (_showPauseMenu) return;
        if (_pendingJump is not null) return;
        if (_showPrologueReplay) return;
        if (!Story.CanAdvance) return;
        if (_transitioning) return;

        // First click also unlocks the audio context for returning users who skip the prologue.
        await MusicSvc.StartAsync();
        if (_lastMoodScene == -1)
        {
            _lastMoodScene = Story.Scene;
            await MusicSvc.SetSceneMoodAsync(Story.Scene);
        }

        await TransitionAdvance();
    }

    private async Task TransitionAdvance()
    {
        if (SettingsSvc.Current.ReduceMotion || SettingsSvc.Current.TextFadeMs <= 0)
        {
            Story.Advance();
            return;
        }

        _transitioning = true;
        StateHasChanged();
        await Task.Delay((int)SettingsSvc.Current.TextFadeMs);
        Story.Advance();
        _transitioning = false;
        StateHasChanged();
    }

    private void OnChoice(int index) => Story.Choose(index);

    private void OpenPanel(TopBar.Panel p)
    {
        _showPauseMenu = false;
        _openPanel = p;
        ResetTimer();
        StateHasChanged();
    }

    private void ClosePanel()
    {
        _openPanel = TopBar.Panel.None;
        ResetTimer();
        StateHasChanged();
    }

    private void OpenPauseMenu()
    {
        _openPanel = TopBar.Panel.None;
        _pendingJump = null;
        _showPauseMenu = true;
        ResetTimer();
        StateHasChanged();
    }

    private void ClosePauseMenu()
    {
        _showPauseMenu = false;
        ResetTimer();
        StateHasChanged();
    }

    private void OpenMenuPanel(TopBar.Panel panel)
    {
        _showPauseMenu = false;
        OpenPanel(panel);
    }

    private async Task ExitApplication()
    {
        await JS.InvokeVoidAsync("visualNovelInput.closeApp");
    }

    private async Task OnPlayAgain()
    {
        await SaveSvc.ClearAsync();
        await JS.InvokeVoidAsync("location.reload");
    }

    private void HandleJump(SceneInfo scene)
    {
        if (scene.Id > Story.Scene)
        {
            // Forward jump — prompt before leaving the bread-crumb trail
            _pendingJump = scene;
            StateHasChanged();
        }
        else
        {
            // Back or same scene — replay/return is safe
            PerformJump(scene);
        }
    }

    private void PerformJump(SceneInfo scene)
    {
        if (Story.JumpToKnot(scene.Knot))
        {
            _openPanel = TopBar.Panel.None;
            _pendingJump = null;
        }
    }

    private void ConfirmJump()
    {
        if (_pendingJump is not null) PerformJump(_pendingJump);
    }

    private void CancelJump()
    {
        _pendingJump = null;
        StateHasChanged();
    }

    private void OpenPrologueReplay()
    {
        _openPanel = TopBar.Panel.None;
        _showPrologueReplay = true;
        _showPauseMenu = false;
        ResetTimer();
        StateHasChanged();
    }

    private void ClosePrologueReplay()
    {
        _showPrologueReplay = false;
        ResetTimer();
        StateHasChanged();
    }

    public void Dispose()
    {
        _autoTimer?.Dispose();
        try { _ = JS.InvokeVoidAsync("visualNovelInput.unbind", _stageRef); } catch { }
        _inputRef?.Dispose();
        Story.StateChanged -= OnStateChanged;
        Story.StateChanged -= OnProgressChanged;
        SettingsSvc.Changed -= OnSettingsChanged;
    }
}
