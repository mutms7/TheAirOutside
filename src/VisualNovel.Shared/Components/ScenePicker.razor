@inject StoryService Story
@implements IDisposable

<div class="panel__header">
    <h2 class="panel__title">Scenes</h2>
    <p class="panel__subtitle">All 15 scenes are accessible. Visited ones carry your gate state; jumping forward into unread scenes will use default state and prompt for confirmation.</p>
</div>

<div class="panel__body scenes">
    @foreach (var scene in SceneRegistry.Scenes)
    {
        var visited = Story.VisitedScenes.Contains(scene.Id);
        var isCurrent = Story.Scene == scene.Id;

        <button class="scene-row @(isCurrent ? "scene-row--current" : "") @(visited ? "" : "scene-row--unvisited")"
                @onclick="@(() => OnJump.InvokeAsync(scene))">
            <div class="scene-row__num">@scene.Id.ToString("00")</div>
            <div class="scene-row__body">
                <div class="scene-row__title">@scene.Title</div>
                @if (scene.Gate is not null)
                {
                    var current = Story.GetVar(scene.Gate);
                    var label = string.IsNullOrEmpty(current) ? "—" : current;
                    <div class="scene-row__meta">gate · @label</div>
                }
                else if (scene.CallbackFrom is not null)
                {
                    <div class="scene-row__meta">callback from scene @scene.CallbackFrom</div>
                }
            </div>
            <div class="scene-row__status">
                @if (isCurrent) { <span class="scene-row__dot" title="current">●</span> }
                else if (visited) { <span class="scene-row__check" title="visited">✓</span> }
                else { <span class="scene-row__unread" title="not yet visited">○</span> }
            </div>
        </button>
    }
</div>

@code {
    [Parameter] public EventCallback<SceneInfo> OnJump { get; set; }

    protected override void OnInitialized() => Story.StateChanged += OnChanged;
    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Story.StateChanged -= OnChanged;
}
