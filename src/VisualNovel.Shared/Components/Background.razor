                    <ellipse cx="900" cy="200" rx="82"  ry="82"  fill="#F5EFD7" opacity="0.95"/>
                    <ellipse cx="876" cy="180" rx="22"  ry="14"  fill="#E0D8B8" opacity="0.4"/>
                    <ellipse class="anim-flicker" cx="800" cy="800" rx="900" ry="280" fill="url(#fc-clearing)"/>
                    <g class="anim-stars" fill="#FFE8A0" opacity="0.78">
                        <circle cx="100"  cy="80"  r="1.6"/>
                        <circle cx="240"  cy="160" r="1"/>
                        <circle cx="380"  cy="100" r="1.2"/>
                        <circle cx="520"  cy="40"  r="1"/>
                        <circle cx="660"  cy="120" r="1.4"/>
                        <circle cx="1140" cy="60"  r="1.2"/>
                        <circle cx="1260" cy="160" r="1"/>
                        <circle cx="1380" cy="80"  r="1.5"/>
                        <circle cx="1500" cy="240" r="1"/>
                        <circle cx="1560" cy="100" r="1.4"/>
                    </g>
                    <g class="anim-fireflies" fill="#FFF6DC" opacity="0.55">
                        <circle cx="500"  cy="600" r="1.2"/>
                        <circle cx="650"  cy="680" r="1.4"/>
                        <circle cx="950"  cy="640" r="1.2"/>
                        <circle cx="1080" cy="720" r="1.4"/>
                        <circle cx="800"  cy="800" r="1.2"/>
                        <circle cx="720"  cy="560" r="1.2"/>
                    </g>
                </svg>
                break;

            default:
                <div class="background__solid" style="background-color: @ColorForId(Id);"></div>
                <div class="background__label">[SCENE @Scene â€” @LabelForId(Id)]</div>
                break;
        }
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";
    [Parameter] public int Scene { get; set; }

    private static string ColorForId(string id) => id switch
    {
        "bedroom-morning" => "#FBE9D7",
        "bedroom-night"   => "#1F1F26",
        "street-morning"  => "#E8DCC9",
        "classroom"       => "#EAE3D2",
        "pe-hall"         => "#D8E4DE",
        "cafeteria"       => "#F0E6D2",
        "hallway-day"     => "#DDE0E6",
        "hallway-night"   => "#252830",
        _                 => "#C8C2B6",
    };

    private static string LabelForId(string id) => id.Replace("-", ", ").ToUpperInvariant();
}
