                        <polygon points="0,500 80,300 160,500"/>
                        <polygon points="120,500 220,260 320,500"/>
                        <polygon points="280,500 380,290 480,500"/>
                        <polygon points="440,500 540,280 640,500"/>
                        <polygon points="1180,500 1280,290 1380,500"/>
                        <polygon points="1340,500 1440,260 1540,500"/>
                        <polygon points="1500,500 1600,290 1600,500"/>
                    </g>
                    <g fill="#1A2235" opacity="0.7">
                        <polygon points="60,500 130,330 200,500"/>
                        <polygon points="200,500 280,320 360,500"/>
                        <polygon points="1220,500 1310,320 1400,500"/>
                        <polygon points="1380,500 1460,310 1540,500"/>
                    </g>
                    <g stroke="#2A3445" stroke-width="2" opacity="0.6">
                        <line x1="50"   y1="700" x2="80"   y2="650"/>
                        <line x1="120"  y1="720" x2="135"  y2="680"/>
                        <line x1="200"  y1="700" x2="210"  y2="660"/>
                        <line x1="280"  y1="730" x2="285"  y2="680"/>
                        <line x1="360"  y1="720" x2="380"  y2="675"/>
                        <line x1="440"  y1="700" x2="445"  y2="660"/>
                        <line x1="540"  y1="730" x2="555"  y2="685"/>
                        <line x1="620"  y1="720" x2="630"  y2="670"/>
                        <line x1="720"  y1="700" x2="730"  y2="660"/>
                        <line x1="820"  y1="730" x2="830"  y2="685"/>
                        <line x1="920"  y1="720" x2="940"  y2="675"/>
                        <line x1="1020" y1="700" x2="1030" y2="660"/>
                        <line x1="1100" y1="730" x2="1115" y2="685"/>
                        <line x1="1200" y1="720" x2="1210" y2="675"/>
                        <line x1="1300" y1="700" x2="1320" y2="655"/>
                        <line x1="1420" y1="720" x2="1430" y2="675"/>
                        <line x1="1500" y1="700" x2="1510" y2="660"/>
                    </g>
                    <g transform="translate(700, 720)">
                        <ellipse cx="100" cy="60" rx="120" ry="22" fill="#0A0D14"/>
                        <rect x="20" y="40" width="160" height="30" rx="14" fill="#3A2D20"/>
                        <ellipse cx="100" cy="40" rx="80" ry="14" fill="#4A3A28"/>
                    </g>
                </svg>
                break;

            case "nurse-office":
                <svg class="background__svg" viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                    <rect width="1600" height="600" fill="#E8E8E0"/>
                    <rect y="600" width="1600" height="300" fill="#C9C9C0"/>
                    <line x1="0" y1="600" x2="1600" y2="600" stroke="#A8A89E" stroke-width="2"/>
                    <rect x="200" y="500" width="700" height="60" fill="#F5F5EF"/>
                    <rect x="220" y="450" width="660" height="50" fill="#FAFAF5"/>
                    <rect x="200" y="560" width="700" height="100" fill="#A8A89E"/>
                    <rect x="200" y="560" width="60"  height="320" fill="#888"/>
                    <rect x="840" y="560" width="60"  height="320" fill="#888"/>
                    <rect x="1100" y="350" width="280" height="280" fill="#D4D4C9"/>
                    <rect x="1110" y="360" width="260" height="40"  fill="#FAFAF5"/>
                    <rect x="1110" y="410" width="260" height="40"  fill="#FAFAF5"/>
                    <rect x="1110" y="460" width="260" height="40"  fill="#FAFAF5"/>
                    <rect x="1110" y="510" width="260" height="40"  fill="#FAFAF5"/>
                    <rect x="1110" y="560" width="260" height="40"  fill="#FAFAF5"/>
                    <g fill="#A8A89E">
                        <circle cx="1240" cy="380" r="3"/>
                        <circle cx="1240" cy="430" r="3"/>
                        <circle cx="1240" cy="480" r="3"/>
                        <circle cx="1240" cy="530" r="3"/>
                        <circle cx="1240" cy="580" r="3"/>
                    </g>
                    <rect x="80" y="200" width="60" height="100" fill="#FAFAF5"/>
                    <svg:text x="110" y="260" text-anchor="middle" font-family="monospace" font-size="14" fill="#888">+</svg:text>
                </svg>
                break;

            case "field-clearing":
                <svg class="background__svg" viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                    <rect width="1600" height="500" fill="#0F1424"/>
                    <rect y="500" width="1600" height="400" fill="#1A2030"/>
                    <ellipse cx="900" cy="200" rx="80" ry="80" fill="#F5EFD7" opacity="0.9"/>
                </svg>
                break;

            default:
                <div class="background__solid" style="background-color: @ColorForId(Id);"></div>
                <div class="background__label">[SCENE @Scene â€” @LabelForId(Id)]</div>
                break;
        }
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";
    [Parameter] public int Scene { get; set; }

    private static string ColorForId(string id) => id switch
    {
        "bedroom-morning" => "#FBE9D7",
        "bedroom-night"   => "#1F1F26",
        "street-morning"  => "#E8DCC9",
        "classroom"       => "#EAE3D2",
        "pe-hall"         => "#D8E4DE",
        "cafeteria"       => "#F0E6D2",
        "hallway-day"     => "#DDE0E6",
        "hallway-night"   => "#252830",
        _                 => "#C8C2B6",
    };

    private static string LabelForId(string id) => id.Replace("-", ", ").ToUpperInvariant();
}
