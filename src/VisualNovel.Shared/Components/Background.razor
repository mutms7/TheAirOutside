                        <circle cx="1080" cy="60"  r="1.4"/>
                        <circle cx="1100" cy="120" r="1"/>
                        <circle cx="1180" cy="200" r="1"/>
                        <circle cx="1240" cy="80"  r="1.5"/>
                        <circle cx="1320" cy="240" r="1"/>
                        <circle cx="1380" cy="160" r="1.2"/>
                        <circle cx="1440" cy="100" r="1"/>
                        <circle cx="1500" cy="120" r="1.5"/>
                        <circle cx="1560" cy="60"  r="1"/>
