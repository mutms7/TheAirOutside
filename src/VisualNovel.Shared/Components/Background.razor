                    <ellipse cx="918" cy="216" rx="14"  ry="9"   fill="#E0D8B8" opacity="0.4"/>
                    <g class="anim-stars" fill="#FFE8A0" opacity="0.78">
                        <circle cx="120"  cy="100" r="1.5"/>
                        <circle cx="180"  cy="220" r="1"/>
                        <circle cx="260"  cy="160" r="1.2"/>
                        <circle cx="320"  cy="60"  r="1"/>
                        <circle cx="380"  cy="80"  r="1.6"/>
                        <circle cx="450"  cy="220" r="1"/>
                        <circle cx="540"  cy="140" r="1"/>
                        <circle cx="600"  cy="60"  r="1.4"/>
                        <circle cx="680"  cy="60"  r="1.5"/>
