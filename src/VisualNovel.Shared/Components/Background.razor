                        <polygon points="440,500 540,280 640,500"  fill="#0A0E1A"/>
                        <polygon points="1180,500 1280,290 1380,500" fill="url(#fn-hill)"/>
                        <polygon points="1340,500 1440,260 1540,500" fill="#0A0E1A"/>
                        <polygon points="1500,500 1600,290 1600,500" fill="url(#fn-hill)"/>
                    </g>
                    <g fill="#1A2235" opacity="0.6">
                        <polygon points="60,500 130,330 200,500"/>
                        <polygon points="200,500 280,320 360,500"/>
                        <polygon points="1220,500 1310,320 1400,500"/>
                        <polygon points="1380,500 1460,310 1540,500"/>
                    </g>
                    <g class="anim-sway" stroke="#2F3A50" stroke-width="2" opacity="0.65" stroke-linecap="round">
                        <line x1="50"   y1="700" x2="80"   y2="650"/>
                        <line x1="120"  y1="720" x2="135"  y2="680"/>
                        <line x1="200"  y1="700" x2="210"  y2="660"/>
                        <line x1="280"  y1="730" x2="285"  y2="680"/>
                        <line x1="360"  y1="720" x2="380"  y2="675"/>
                        <line x1="440"  y1="700" x2="445"  y2="660"/>
