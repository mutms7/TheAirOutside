                    <rect x="200" y="560" width="700" height="6" fill="#FFFFFF" opacity="0.3"/>
                    <rect x="200" y="560" width="60" height="320" rx="3" fill="#787870"/>
                    <rect x="840" y="560" width="60" height="320" rx="3" fill="#787870"/>
                    <path d="M 1100 350 L 1380 350 L 1380 630 L 1100 630 Z" fill="url(#no-cabinet)" stroke="#8E8E84" stroke-width="2"/>
