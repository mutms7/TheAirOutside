                    }
                    <g transform="translate(80 200)">
                        <rect width="60" height="100" rx="4" fill="#FAFAF5"/>
                        <rect width="60" height="8" fill="#FFFFFF" opacity="0.55"/>
                        <rect x="22" y="38" width="16" height="34" fill="#D63B3B" opacity="0.85"/>
