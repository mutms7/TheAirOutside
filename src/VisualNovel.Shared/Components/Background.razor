                            <stop offset="0%"  stop-color="#1A2030"/>
                            <stop offset="100%" stop-color="#0B1020"/>
                        </linearGradient>
                        <radialGradient id="fn-moon" cx="0.5" cy="0.5" r="0.6">
                            <stop offset="0%"  stop-color="#F5EFD7" stop-opacity="0.9"/>
                            <stop offset="25%" stop-color="#E5DCC4" stop-opacity="0.4"/>
                            <stop offset="100%" stop-color="#9CA0B0" stop-opacity="0"/>
                        </radialGradient>
                        <linearGradient id="fn-hill" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%"  stop-color="#1A2236"/>
                            <stop offset="100%" stop-color="#0E1320"/>
                        </linearGradient>
                    </defs>
                    <rect width="1600" height="500" fill="url(#fn-sky)"/>
