                </svg>
                break;

            case "field-clearing":
                <svg class="background__svg" viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                    <defs>
                        <linearGradient id="fc-sky" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%"  stop-color="#0A0E1F"/>
                            <stop offset="60%" stop-color="#15192E"/>
                            <stop offset="100%" stop-color="#202442"/>
                        </linearGradient>
                        <linearGradient id="fc-ground" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%"  stop-color="#1A2236"/>
                            <stop offset="100%" stop-color="#0E1320"/>
                        </linearGradient>
                        <radialGradient id="fc-moon" cx="0.5" cy="0.5" r="0.6">
                            <stop offset="0%"  stop-color="#F5EFD7" stop-opacity="0.95"/>
                            <stop offset="25%" stop-color="#E5DCC4" stop-opacity="0.42"/>
                            <stop offset="100%" stop-color="#9CA0B0" stop-opacity="0"/>
                        </radialGradient>
                        <radialGradient id="fc-clearing" cx="0.5" cy="0.6" r="0.55">
                            <stop offset="0%"  stop-color="#F5EFD7" stop-opacity="0.18"/>
                            <stop offset="100%" stop-color="#F5EFD7" stop-opacity="0"/>
                        </radialGradient>
                    </defs>
                    <rect width="1600" height="500" fill="url(#fc-sky)"/>
                    <rect y="500" width="1600" height="400" fill="url(#fc-ground)"/>
